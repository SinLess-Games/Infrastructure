#cloud-config
#
# Goals:
# - Minimal + deterministic first boot
# - SSH key-only access using the shared provisioning key
# - Drop structured node context for later bootstrap (Ansible/Vault/etc.)
# - Avoid any Jinja-only time functions (no custom filters required)

preserve_hostname: false
hostname: pve-01
manage_etc_hosts: true

ssh_pwauth: false
disable_root: false

users:
  - default

  # Dedicated provisioning user (recommended)
  - name: provision
    gecos: "PXE Provisioning User"
    groups: [adm, sudo]
    shell: /bin/bash
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    lock_passwd: true
    ssh_authorized_keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHjg8twRRKjz+lRycGIOQtrXSg/JGor4zqXzAo3+z6EW pxe-provisioning"

  # Root key access allowed, but no passwords
  - name: root
    lock_passwd: true
    ssh_authorized_keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHjg8twRRKjz+lRycGIOQtrXSg/JGor4zqXzAo3+z6EW pxe-provisioning"

package_update: true
package_upgrade: false
packages:
  - ca-certificates
  - curl
  - gnupg
  - openssh-server
  - sudo
  - jq

write_files:
  # Harden SSH: key-only, no passwords. Root allowed only via keys.
  - path: /etc/ssh/sshd_config.d/10-pxe-hardening.conf
    permissions: "0644"
    owner: root:root
    content: |
      PasswordAuthentication no
      KbdInteractiveAuthentication no
      ChallengeResponseAuthentication no
      PubkeyAuthentication yes
      PermitRootLogin prohibit-password

  # Node context for later automation
  - path: /etc/pxe/node.json
    permissions: "0644"
    owner: root:root
    content: |
      {
  "debian_arch": "amd64",
  "debian_release": "bookworm",
  "dns": [
    "10.10.10.1"
  ],
  "domain": "local.sinlessgames.com",
  "fqdn": "pve-01.local.sinlessgames.com",
  "gateway": "10.10.10.1",
  "hostname": "pve-01",
  "ip": "10.10.10.5",
  "mac": "00:d8:61:33:97:84",
  "pxe_http_host": "local.sinlessgames.com",
  "subnet": "10.10.10.0/24",
  "vlan": "mgmt"
}

  # Simple marker for "this came from PXE"
  - path: /etc/pxe/provisioned
    permissions: "0644"
    owner: root:root
    content: |
      provisioned=true
      hostname=pve-01

runcmd:
  - [ sh, -lc, "mkdir -p /etc/pxe /var/log/pxe" ]

  # Ensure SSH is enabled (Debian service name is usually ssh)
  - [ sh, -lc, "systemctl enable --now ssh || systemctl enable --now sshd || true" ]
  - [ sh, -lc, "systemctl reload ssh || systemctl reload sshd || true" ]

  # Runtime timestamp (no Jinja strftime needed)
  - [ sh, -lc, "date -Is > /etc/pxe/provisioned-at" ]

  # Lightweight audit trail
  - [ sh, -lc, "echo 'PXE provisioning complete at '\"$(date -Is)\"' for pve-01' | tee /var/log/pxe/provisioning.log" ]
  - [ sh, -lc, "printf '%s\n' 'Provisioned via PXE at '\"$(date -Is)\" > /root/PROVISIONED.txt" ]

final_message: "PXE provisioning complete for pve-01. SSH ready (key-only)."