#!ipxe
# PXE/config/menus/local-vars.ipxe
# Loaded automatically by netboot.xyz before building menus.

# next-server comes from DHCP (option 66). Fallback for safety.
isset ${next-server} || set next-server 10.10.10.10
set pxe http://${next-server}

# Enable custom menu support + add a Custom URL shortcut
set menu custom-user
set custom_url ${pxe}/auto-install/menu.ipxe
