# MinIO Environment Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Root credentials
MINIO_ROOT_USER="{{ vault_runtime_secrets.root_user }}"
MINIO_ROOT_PASSWORD="{{ vault_runtime_secrets.root_password }}"

# Server configuration
MINIO_VOLUMES="{{ minio_effective_volumes }}"
MINIO_OPTS="--console-address {{ ((hostvars[inventory_hostname].ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname), true)) ~ ':' ~ (minio_console_port | string)) if (minio_bind_to_host_ip | bool) else (':' ~ (minio_console_port | string)) }} --address {{ ((hostvars[inventory_hostname].ansible_host | default(ansible_default_ipv4.address | default(inventory_hostname), true)) ~ ':' ~ (minio_api_port | string)) if (minio_bind_to_host_ip | bool) else (':' ~ (minio_api_port | string)) }}{% if minio_tls_enabled | bool %} --certs-dir {{ minio_config_dir }}/certs{% endif %}"
MINIO_SITE_NAME="{{ minio_site_name }}"
MINIO_SERVER_URL="{{ minio_effective_scheme }}://{{ minio_effective_server_host }}{% if haproxy_enabled | bool %}{% if (haproxy_frontend_port | int) not in [80, 443] %}:{{ haproxy_frontend_port }}{% endif %}{% else %}:{{ minio_api_port }}{% endif %}"
{% if minio_console_fqdn | default('', true) | length > 0 %}
MINIO_BROWSER_REDIRECT_URL="{{ minio_effective_scheme }}://{{ minio_console_fqdn }}{% if haproxy_enabled | bool %}{% if (haproxy_frontend_port | int) not in [80, 443] %}:{{ haproxy_frontend_port }}{% endif %}{% else %}{% if (minio_console_port | int) not in [80, 443] %}:{{ minio_console_port }}{% endif %}{% endif %}"
{% endif %}

# Browser configuration
MINIO_BROWSER=on

# Performance tuning
MINIO_API_REQUESTS_MAX=10000
MINIO_API_REQUESTS_DEADLINE=10s

# Logging
MINIO_LOG_LEVEL=INFO
