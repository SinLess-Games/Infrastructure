# =============================================================================
# HAProxy Configuration for MinIO Load Balancing
# Generated by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon

    # Default SSL material locations
    ca-base /etc/ssl/certs
    crt-base /etc/ssl/private

    # Security and performance tuning
    ssl-default-bind-ciphers ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets
    tune.ssl.default-dh-param 2048
    maxconn 40000

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  http-server-close
    option  forwardfor except 127.0.0.0/8
    option  redispatch
    retries 3
    timeout connect 5000
    timeout client  50000
    timeout server  50000
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

# =============================================================================
# Statistics
# =============================================================================
listen stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ (vault_runtime_secrets | default({}, true)).haproxy_stats_password | default(minio_haproxy_stats_password, true) }}
    stats refresh 30s
    stats show-legends
    stats show-node

# =============================================================================
# MinIO API Frontend (direct VIP:9000)
# =============================================================================
frontend minio_api_frontend
    bind {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}:{{ minio_api_port }}
    mode http
    default_backend minio_s3_backend

# =============================================================================
# MinIO Console Frontend (direct VIP:9001)
# =============================================================================
frontend minio_console_frontend
    bind {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}:{{ minio_console_port }}
    mode http
    default_backend minio_console_backend

# =============================================================================
# MinIO Web Frontend (port 80, host-based routing)
# =============================================================================
frontend minio_web_frontend
    bind {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}:{{ haproxy_frontend_port }}
    mode http

    # Route Console requests by Host header
    acl minio_console_host hdr(host) -i {{ minio_console_fqdn }}
    use_backend minio_console_backend if minio_console_host

    # Route API requests by Host header (if provided)
    acl minio_api_host hdr(host) -i {{ minio_api_fqdn }}
    use_backend minio_s3_backend if minio_api_host

    # Default route for bare VIP access: Console UI
    default_backend minio_console_backend

# =============================================================================
# MinIO S3 API Backend
# =============================================================================
backend minio_s3_backend
    mode http
    balance roundrobin
    option httpchk
    http-check send meth GET uri /minio/health/live ver HTTP/1.1 hdr Host localhost
    http-check expect status 200
    
    # MinIO servers
{% for host in groups['minio'] %}
    server {{ host }} {{ hostvars[host].ansible_host }}:{{ minio_api_port }} check inter 2000 rise 2 fall 3
{% endfor %}

# =============================================================================
# MinIO Console Backend
# =============================================================================
backend minio_console_backend
    mode http
    balance roundrobin
    option httpchk GET /
    
    # MinIO console servers
{% for host in groups['minio'] %}
    server {{ host }}-console {{ hostvars[host].ansible_host }}:{{ minio_console_port }} check inter 2000 rise 2 fall 3
{% endfor %}
