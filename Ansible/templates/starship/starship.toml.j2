"$schema" = "https://starship.rs/config-schema.json"

# =====================================================================
# Starship Prompt — SinLess Games Theme
# =====================================================================

add_newline = true
command_timeout = 20000

format = """
[╔══════════════════════════](bold acc) $os$localip $username[| ](bold ok)[$hostname](bold blue) $time [═════════════════════════════╗](bold acc)
[║](bold acc)[  Git](bold ok)  $git_branch $git_status $git_metrics 
[║](bold acc)[  Conditionals](bold ok) $kubernetes $helm $terraform $docker_context $aws $gcloud $azure $package 
[║](bold acc)[  Languages](bold ok) $nodejs $python $golang $rust 
[║](bold acc)[  Dir](bold ok) $directory
[╚══>](bold acc) $cmd_duration$status $character
"""

# =====================================================================
# Palette
# =====================================================================
palette = "sinless"
[palettes.sinless]
ok    = "green"
warn  = "yellow"
err   = "red"
dim   = "bright-black"
acc   = "cyan"
brand = "magenta"

# =====================================================================
# Prompt Character
# =====================================================================
[character]
success_symbol         = "[➜](bold ok) "
error_symbol           = "[✗](bold err) "
vimcmd_symbol          = "[❮](bold ok) "
vimcmd_replace_symbol  = "[❮](bold warn) "
vimcmd_visual_symbol   = "[❮](bold brand) "

# =====================================================================
# User / Host / System
# =====================================================================
[localip]
ssh_only = false
disabled = false

[username]
show_always = true
format = "[$user](bold acc) "

[hostname]
ssh_only = false
format = "[@$hostname](bold blue) "

[os]
format = "[$symbol]($style) "
style = "bold dim"

# =====================================================================
# Directory
# =====================================================================
[directory]
truncation_length = 3
truncate_to_repo  = true
style = "bold"
format = "[$path]($style) "
home_symbol = "~"

[directory.substitutions]
"Documents" = "󰈙 "
"Downloads" = "󰇚 "
"Workspace" = "💼 "
"Projects"  = "🛠 "

# =====================================================================
# Git
# =====================================================================
[git_branch]
symbol = "🌿"
style = "bold ok"
format = "[$symbol $branch]($style)"

[git_status]
style  = "bold warn"
format = " [• $all_status$ahead_behind •]($style)"

stashed    = " 📦 $count"
conflicted = " ⚔ $count"
deleted    = " 🗑 $count"
renamed    = " 🔄 $count"
modified   = " 📝 $count"
staged     = " ✅ $count"
untracked  = " ✨ $count"
ahead      = " ⬆ $count"
behind     = " ⬇ $count"
diverged   = " ⇕ $ahead_count/$behind_count"

[git_commit]
commit_hash_length = 7
tag_disabled = true
format = " [# $hash]($style)"
style = "dim"

[git_metrics]
disabled      = false
added_style   = "bold ok"
deleted_style = "bold err"
format        = " ([+$added]($added_style) [-$deleted]($deleted_style))"

# =====================================================================
# Kubernetes
# =====================================================================
[kubernetes]
format = 'on [☸ ($user@)$context (\($namespace\))](bold acc) '
disabled = false
detect_folders = ["k8s",".kube"]
detect_files   = ["kubeconfig",".kubeconfig"]

[[kubernetes.contexts]]
context_pattern = '^gke_.*_(.*)$'
style = "bold ok"
symbol = "⛵ "
context_alias = "gke-$1"

[[kubernetes.contexts]]
context_pattern = '.*openshift.*'
style = "bold err"
symbol = "💔 "
context_alias = "openshift"

[[kubernetes.contexts]]
context_pattern = '.*dev.*'
style = "bold warn"
symbol = "🔧 "
context_alias = "dev"

[[kubernetes.contexts]]
context_pattern = '.*prod.*'
style = "bold brand"
symbol = "🔥 "
context_alias = "prod"

[[kubernetes.contexts]]
context_pattern = '^minikube$|^kind.*$'
style = "bold acc"
symbol = "💻 "
context_alias = "local"

# =====================================================================
# Cloud Providers
# =====================================================================
[aws]
format = 'on [ $profile( \($region\))]($style) '
style = "bold brand"
disabled = true

[gcloud]
format = 'on [☁ $account(@$domain) \($region\)]($style) '
style = "bold brand"
disabled = true

[azure]
format = 'on [󰠠 $subscription]($style) '
style = "bold brand"
disabled = true

# =====================================================================
# Tools
# =====================================================================
[helm]
format = 'via [⚓ $version](bold acc) '
symbol = '⎈ '
style = 'bold acc'
version_format = 'v${raw}'
detect_files   = ["helmfile.yaml","Chart.yaml"]
detect_folders = ["charts","helm"]

[terraform]
format = 'via [🧱 $version$workspace]($style) '
style = "bold brand"
version_format = 'v${raw}'
detect_extensions = ["tf","tfvars"]

[docker_context]
symbol = "🐳 "
format = "via [$symbol$context]($style) "
style = "bold acc"
only_with_files = true

[nodejs]
disabled = true

[golang]
format = "via [ $version]($style) "
style = "bold ok"

[rust]
format = "via [🦀 $version]($style) "
style = "bold ok"

[python]
format = '[${symbol}${virtualenv}${version}]($style) '
style = "bold warn"
symbol = " "
python_binary = "python3"

[package]
format = "[$symbol$version]($style) "
style = "dimmed"
symbol = "📦 "

# =====================================================================
# System Info / Status / Time
# =====================================================================
[cmd_duration]
min_time = 2000
format = " [took $duration]($style)"
style = "bold dim"

[status]
disabled = false
format = " [$symbol]($style)"
symbol = "✗"
success_symbol = "✅"
not_executable_symbol = "…"
style = "bold err"
success_style = "bold ok"

[battery]
full_symbol        = "🔋 "
charging_symbol    = "⚡ "
discharging_symbol = "🔌 "

[time]
disabled = false
use_12hr = true
time_format = "%I:%M:%S %p"
style = "bold dim acc"
format = " [🕒 $time]($style)"