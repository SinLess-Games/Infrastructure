global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
{% if haproxy_global_lua_load is defined and haproxy_global_lua_load %}
    lua-load {{ haproxy_global_lua_load }}
{% endif %}
    daemon
{% if haproxy_global_ca_base is defined and haproxy_global_ca_base %}

    ca-base /etc/ssl/certs
    crt-base /etc/ssl/private
{% endif %}
{% if haproxy_global_ssl_defaults is defined and haproxy_global_ssl_defaults %}

    ssl-default-bind-ciphers ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets
    tune.ssl.default-dh-param 2048
{% endif %}
{% if haproxy_global_maxconn is defined and haproxy_global_maxconn %}
    maxconn {{ haproxy_global_maxconn }}
{% endif %}
