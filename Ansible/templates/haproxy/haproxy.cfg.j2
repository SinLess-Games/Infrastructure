{% if routing_profile == 'minio' %}
# =============================================================================
# HAProxy Configuration for MinIO Load Balancing
# Generated by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

{% set haproxy_global_ca_base = true %}
{% set haproxy_global_ssl_defaults = true %}
{% set haproxy_global_maxconn = 40000 %}
{% include 'global.j2' %}

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  http-server-close
    option  forwardfor except 127.0.0.0/8
    option  redispatch
    retries 3
    timeout connect 5000
    timeout client  50000
    timeout server  50000
{% include 'errorfiles.j2' %}

listen stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /
    stats realm HAProxy\ Statistics
    stats auth {{ haproxy_stats_user }}:{{ (vault_runtime_secrets | default({}, true)).haproxy_stats_password | default(minio_haproxy_stats_password, true) }}
    stats refresh 30s
    stats show-legends
    stats show-node

frontend minio_api_frontend
    bind {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}:{{ minio_api_port }}
    mode http
    default_backend minio_s3_backend

frontend minio_console_frontend
    bind {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}:{{ minio_console_port }}
    mode http
    default_backend minio_console_backend

frontend minio_web_frontend
    bind {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}:{{ haproxy_frontend_port }}
    mode http

    acl minio_console_host hdr(host) -i {{ minio_console_fqdn }}
    use_backend minio_console_backend if minio_console_host

    acl minio_api_host hdr(host) -i {{ minio_api_fqdn }}
    use_backend minio_s3_backend if minio_api_host

    default_backend minio_console_backend

backend minio_s3_backend
    mode http
    balance roundrobin
    option httpchk
    http-check send meth GET uri /minio/health/live ver HTTP/1.1 hdr Host localhost
    http-check expect status 200
{% for host in groups['minio'] %}
    server {{ host }} {{ hostvars[host].ansible_host }}:{{ minio_api_port }} check inter 2000 rise 2 fall 3
{% endfor %}

backend minio_console_backend
    mode http
    balance roundrobin
    option httpchk GET /
{% for host in groups['minio'] %}
    server {{ host }}-console {{ hostvars[host].ansible_host }}:{{ minio_console_port }} check inter 2000 rise 2 fall 3
{% endfor %}
{% elif routing_profile == 'postgres' %}
# HAProxy configuration for {{ postgres_cluster_name }}
# Managed by Ansible - DO NOT EDIT MANUALLY

{% set haproxy_global_maxconn = 1000 %}
{% include 'global.j2' %}

defaults
    mode tcp
    log global
    option tcplog
    option dontlognull
    timeout connect 5000
    timeout client 50000
    timeout server 50000
{% include 'errorfiles.j2' %}

listen stats
    mode http
    bind *:{{ haproxy_stats_port }}
    stats enable
    stats uri /
    stats realm Haproxy\ Statistics
    stats refresh 30s

frontend pgadmin
    mode http
    bind {{ postgres_vip_ip }}:{{ postgres_pgadmin_port }}
    option httplog
    default_backend pgadmin

backend pgadmin
    mode http
    balance source
    option httpchk GET /misc/ping
    http-check expect status 200
{% for node in postgres_nodes %}
    server {{ node.name }} {{ node.ip }}:{{ postgres_pgadmin_backend_port }} check inter 2000 rise 2 fall 3
{% endfor %}

listen postgres-primary
    bind {{ postgres_vip_ip }}:{{ postgres_listen_port }}
    option httpchk GET /primary
    http-check expect status 200
    default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions
{% for node in postgres_nodes %}
    server {{ node.name }} {{ node.ip }}:{{ postgres_listen_port }} maxconn 100 check port {{ patroni.restapi_port }} inter 2000 rise 2 fall 3
{% endfor %}

listen postgres-standby
    bind {{ postgres_vip_ip }}:{{ postgres_readonly_port }}
    option httpchk GET /replica
    http-check expect status 200
    default-server inter 3s fall 3 rise 2 on-marked-down shutdown-sessions
{% for node in postgres_nodes %}
    server {{ node.name }} {{ node.ip }}:{{ postgres_listen_port }} maxconn 100 check port {{ patroni.restapi_port }} inter 2000 rise 2 fall 3
{% endfor %}
{% elif routing_profile == 'vault' %}
# HAProxy configuration for Vault load balancing

{% set haproxy_global_lua_load = '/etc/haproxy/terraform-vault-auth.lua' %}
{% include 'global.j2' %}

defaults
  log     global
  mode    tcp
  option  tcplog
  timeout connect 5000ms
  timeout client  50000ms
  timeout server  50000ms

defaults http-defaults
  mode    http
  option  httplog
  timeout connect 5000ms
  timeout client  50000ms
  timeout server  50000ms
  timeout http-request 10s
  timeout http-keep-alive 10s

listen stats
  bind 0.0.0.0:8404
  stats enable
  stats uri /stats
  stats refresh 30s
  stats show-legends

listen vault-api-443
  bind {{ vault_haproxy_bind_address }}:443
  mode tcp
  balance roundrobin
  default-server inter 10s fall 3 rise 2
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_service_api_port }}
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_service_api_port }}
{% endfor %}
{% endif %}

listen vault-api-8200
  bind {{ vault_haproxy_bind_address }}:{{ vault_api_addr_port }}
  mode tcp
  balance roundrobin
  default-server inter 10s fall 3 rise 2
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_service_api_port }}
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_service_api_port }}
{% endfor %}
{% endif %}

listen vault-cluster
  bind {{ vault_haproxy_bind_address }}:{{ vault_cluster_addr_port }}
  mode tcp
  balance roundrobin
  default-server inter 10s fall 3 rise 2
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_service_cluster_port }}
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_service_cluster_port }}
{% endfor %}
{% endif %}

frontend terraform-state-http
  bind {{ vault_haproxy_bind_address }}:8180 ssl crt /etc/haproxy/vault-combined.pem
  mode http
  option httplog
  option forwardfor
  http-request lua.terraform_vault_auth
  default_backend vault-kv-api

backend vault-kv-api
  mode http
  balance roundrobin
  option httpchk GET /v1/sys/health
  http-check expect status 200
  http-response lua.unwrap_vault_response
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_service_api_port }} check ssl verify none
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_service_api_port }} check ssl verify none
{% endfor %}
{% endif %}
{% else %}
# Unsupported routing profile: {{ routing_profile }}
{% endif %}
