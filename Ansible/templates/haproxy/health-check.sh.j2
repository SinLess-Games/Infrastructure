#!/bin/bash
{% if routing_profile == 'minio' %}
# Keepalived Health Check Script for HAProxy
# Generated by Ansible - DO NOT EDIT MANUALLY

if ! pgrep -x haproxy > /dev/null; then
    exit 1
fi

if ! haproxy -c -q -f /etc/haproxy/haproxy.cfg; then
    exit 1
fi

if ! ss -ltn | grep -qE '(:{{ minio_api_port }}|:{{ minio_console_port }})'; then
    exit 1
fi

exit 0
{% elif routing_profile == 'postgres' %}
# HAProxy health check script for Keepalived
# Managed by Ansible - DO NOT EDIT MANUALLY

if ! systemctl is-active --quiet haproxy; then
    exit 1
fi

curl -sf http://127.0.0.1:{{ haproxy_stats_port }}/ > /dev/null 2>&1
exit $?
{% elif routing_profile == 'vault' %}
# Health check script for Vault - used by Keepalived

VAULT_ADDR="{{ vault_local_api_addr }}"
VAULT_SKIP_VERIFY="true"

HEALTH_JSON=$(curl -sk --connect-timeout 2 "${VAULT_ADDR}/v1/sys/health" 2>/dev/null)
INITIALIZED=$(echo "${HEALTH_JSON}" | jq -r '.initialized' 2>/dev/null)
SEALED=$(echo "${HEALTH_JSON}" | jq -r '.sealed' 2>/dev/null)

if [ "${INITIALIZED}" = "true" ] && [ "${SEALED}" = "false" ]; then
  exit 0
else
  exit 1
fi
{% else %}
echo "Unsupported routing profile: {{ routing_profile }}" >&2
exit 1
{% endif %}
