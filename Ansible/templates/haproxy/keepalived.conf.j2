{% if routing_profile == 'minio' %}
# =============================================================================
# Keepalived Configuration for MinIO VIP Management
# Generated by Ansible - DO NOT EDIT MANUALLY
# =============================================================================

{% set keepalived_router_id_value = 'minio_' ~ inventory_hostname %}
{% set keepalived_script_user = 'root' %}
{% include 'keepalived-global-defs.j2' %}

vrrp_script check_haproxy {
    script "/etc/keepalived/check_haproxy.sh"
    interval {{ keepalived_check_interval }}
    weight -20
    fall 2
    rise 2
}

vrrp_instance MINIO_VIP {
    state {% if inventory_hostname == groups['minio'][0] %}MASTER{% else %}BACKUP{% endif %}
    interface {{ (vault_runtime_secrets | default({}, true)).vip_interface | default(minio_vip_interface | default(ansible_default_ipv4.interface, true), true) }}
    virtual_router_id {{ keepalived_router_id }}
    priority {{ keepalived_priority }}
    advert_int 1
    authentication {
        auth_type {{ keepalived_auth_type }}
        auth_pass {{ ((vault_runtime_secrets | default({}, true)).keepalived_password | default(minio_keepalived_password, true) | string)[:8] }}
    }
    virtual_ipaddress {
        {{ (vault_runtime_secrets | default({}, true)).vip_address | default(minio_vip_address, true) }}/{{ minio_vip_prefix }}
    }
    track_script {
        check_haproxy
    }
    notify_master "/bin/echo 'MinIO VIP is now MASTER on {{ inventory_hostname }}' | logger -t keepalived"
    notify_backup "/bin/echo 'MinIO VIP is now BACKUP on {{ inventory_hostname }}' | logger -t keepalived"
    notify_fault "/bin/echo 'MinIO VIP is in FAULT state on {{ inventory_hostname }}' | logger -t keepalived"
}
{% elif routing_profile == 'postgres' %}
# Keepalived configuration for {{ inventory_hostname }}
# Managed by Ansible - DO NOT EDIT MANUALLY

{% set keepalived_router_id_value = inventory_hostname %}
{% set keepalived_script_user = 'root' %}
{% set postgres_keepalived_state = 'MASTER' if inventory_hostname == postgres_nodes[0].name else 'BACKUP' %}
{% include 'keepalived-global-defs.j2' %}

vrrp_script check_haproxy {
    script "/usr/local/bin/check-haproxy.sh"
    interval 2
    weight 2
    fall 2
    rise 2
}

vrrp_instance VI_{{ postgres_keepalived_vrid }} {
    state {{ postgres_keepalived_state }}
    interface {{ postgres_vip_iface }}
    virtual_router_id {{ postgres_keepalived_vrid }}
    priority {{ postgres_nodes | selectattr('name', 'equalto', inventory_hostname) | map(attribute='keepalived_priority') | first }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass {{ (postgres_keepalived_auth_pass | string)[:8] }}
    }
    virtual_ipaddress {
        {{ postgres_vip_ip }}/{{ postgres_vip_cidr }} dev {{ postgres_vip_iface }}
    }
    track_script {
        check_haproxy
    }
    notify_master "/usr/bin/logger -t keepalived 'Transitioned to MASTER state on {{ inventory_hostname }}'"
    notify_backup "/usr/bin/logger -t keepalived 'Transitioned to BACKUP state on {{ inventory_hostname }}'"
    notify_fault "/usr/bin/logger -t keepalived 'Transitioned to FAULT state on {{ inventory_hostname }}'"
}
{% elif routing_profile == 'vault' %}
---
# Keepalived configuration for Vault VIP

{% set keepalived_router_id_value = 'vault-ha' %}
{% set keepalived_script_user = 'vault' %}
{% include 'keepalived-global-defs.j2' %}

vrrp_script check_vault {
  script "/usr/local/bin/check-vault-health.sh"
  interval 5
  weight -10
  fall 3
  rise 2
}

vrrp_instance vault_vip {
  state BACKUP
  interface {{ vault_keepalived_interface }}
  virtual_router_id 51
  priority {{ vault_keepalived_priority }}
  advert_int 1
  authentication {
    auth_type PASS
    auth_pass {{ vault_keepalived_password | default('vault-ha-123') }}
  }
  virtual_ipaddress {
    {{ vault_keepalived_virtual_ip }}/24
  }
  track_script {
    check_vault
  }
  notify_master "/usr/local/bin/vault-vip-master.sh"
  notify_backup "/usr/local/bin/vault-vip-backup.sh"
  notify_fault "/usr/local/bin/vault-vip-fault.sh"
}
{% else %}
# Unsupported routing profile: {{ routing_profile }}
{% endif %}
