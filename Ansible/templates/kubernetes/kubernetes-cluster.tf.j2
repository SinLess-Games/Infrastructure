// =====================================================================
// Kubernetes {{ kubernetes_environment }} Cluster Terraform Configuration (Managed by Ansible)
// =====================================================================
// Source: Ansible/templates/kubernetes/kubernetes-cluster.tf.j2
// DO NOT EDIT MANUALLY
// =====================================================================

module "kubernetes_{{ kubernetes_environment }}_masters" {
  source = "./modules/kubernetes-master"

  cluster_name   = "{{ kubernetes_cluster_name }}"
  environment    = "{{ kubernetes_environment }}"
  node_role      = "control-plane"
  clone_template = "debian-13-template"
  force_create   = {{ (kubernetes_force_create | default(false)) | ternary('true', 'false') }}
  proxmox_node_ssh_hosts = {
{% for node_name, ssh_host in kubernetes_proxmox_node_ssh_hosts.items() %}
    "{{ node_name }}" = "{{ ssh_host }}"
{% endfor %}
  }

  network_bridge = "{{ kubernetes_network.bridge }}"
  vlan_id        = {{ kubernetes_network.vlan_id }}
  gateway        = "{{ kubernetes_network.gateway }}"
  cidr_subnet    = "{{ kubernetes_network.cidr_suffix }}"
  nameservers    = "{{ kubernetes_network.nameservers }}"

  cpu_cores   = {{ kubernetes_control_plane.cpu_cores }}
  cpu_sockets = {{ kubernetes_control_plane.cpu_sockets }}
  memory_mb   = {{ kubernetes_control_plane.memory_mb }}
  disk_size   = "{{ kubernetes_control_plane.disk_size }}"
  storage     = "{{ kubernetes_storage }}"
  resource_pool = "{{ kubernetes_resource_pool }}"

  tags = ["kubernetes", "{{ kubernetes_environment }}", "control-plane"]

  nodes = [
{% for node in kubernetes_nodes.control_plane %}
    {
      name        = "{{ node.name }}"
      vmid        = {{ node.vmid }}
      target_node = "{{ node.target_node }}"
      ip_address  = "{{ node.ip }}"
      hostname    = "{{ node.hostname }}"
      fqdn        = "{{ node.fqdn }}"
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
}

module "kubernetes_{{ kubernetes_environment }}_workers" {
  source = "./modules/kubernetes-worker"

  cluster_name   = "{{ kubernetes_cluster_name }}"
  environment    = "{{ kubernetes_environment }}"
  node_role      = "worker"
  clone_template = "debian-13-template"
  force_create   = {{ (kubernetes_force_create | default(false)) | ternary('true', 'false') }}
  proxmox_node_ssh_hosts = {
{% for node_name, ssh_host in kubernetes_proxmox_node_ssh_hosts.items() %}
    "{{ node_name }}" = "{{ ssh_host }}"
{% endfor %}
  }

  network_bridge = "{{ kubernetes_network.bridge }}"
  vlan_id        = {{ kubernetes_network.vlan_id }}
  gateway        = "{{ kubernetes_network.gateway }}"
  cidr_subnet    = "{{ kubernetes_network.cidr_suffix }}"
  nameservers    = "{{ kubernetes_network.nameservers }}"

  cpu_cores   = {{ kubernetes_workers.cpu_cores }}
  cpu_sockets = {{ kubernetes_workers.cpu_sockets }}
  memory_mb   = {{ kubernetes_workers.memory_mb }}
  disk_size   = "{{ kubernetes_workers.disk_size }}"
  storage     = "{{ kubernetes_storage }}"
  resource_pool = "{{ kubernetes_resource_pool }}"

  tags = ["kubernetes", "{{ kubernetes_environment }}", "worker"]

  nodes = [
{% for node in kubernetes_nodes.workers %}
    {
      name        = "{{ node.name }}"
      vmid        = {{ node.vmid }}
      target_node = "{{ node.target_node }}"
      ip_address  = "{{ node.ip }}"
      hostname    = "{{ node.hostname }}"
      fqdn        = "{{ node.fqdn }}"
    }{% if not loop.last %},{% endif %}
{% endfor %}
  ]
}

output "kubernetes_{{ kubernetes_environment }}_control_plane_hosts" {
  value = module.kubernetes_{{ kubernetes_environment }}_masters.ansible_hosts
}

output "kubernetes_{{ kubernetes_environment }}_worker_hosts" {
  value = module.kubernetes_{{ kubernetes_environment }}_workers.ansible_hosts
}

output "kubernetes_{{ kubernetes_environment }}_all_hosts" {
  value = merge(
    module.kubernetes_{{ kubernetes_environment }}_masters.ansible_hosts,
    module.kubernetes_{{ kubernetes_environment }}_workers.ansible_hosts
  )
}
