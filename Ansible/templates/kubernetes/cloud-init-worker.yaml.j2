#cloud-config
# Kubernetes Worker Node Cloud-Init Configuration
# Generated by Ansible - kubernetes-deploy role

version: 2

hostname: k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }}
fqdn: k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }}.{{ kubernetes_deploy_search_domain | default(kubernetes_deploy_environment ~ '.sinlessgames.local') }}

locale: en_US.UTF-8
timezone: UTC

package_update: true
package_upgrade: true

packages:
  - qemu-guest-agent
  - curl
  - wget
  - net-tools
  - vim
  - htop
  - sudo

users:
  - name: {{ kubernetes_default_user | default('sinless777') }}
    gecos: SinLess Administrator
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: [adm, sudo]
    ssh_authorized_keys:
{% for ssh_key in kubernetes_deploy_ssh_keys | default([]) %}
      - {{ ssh_key }}
{% endfor %}

write_files:
  - path: /etc/hostname
    permissions: '0644'
    owner: root:root
    content: |
      k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }}

  - path: /etc/hosts
    permissions: '0644'
    owner: root:root
    content: |
      127.0.0.1 localhost
      127.0.1.1 k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }} k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }}.{{ kubernetes_deploy_search_domain | default(kubernetes_deploy_environment ~ '.sinlessgames.local') }}
      ::1 localhost ip6-localhost ip6-loopback
      ff02::1 ip6-allnodes
      ff02::2 ip6-allrouters

  - path: /etc/qemu-ga/client.conf
    permissions: '0644'
    owner: root:root
    content: |
      [general]
      logfile = /var/log/qemu-ga/client.log

  - path: /etc/cloud/cloud.cfg.d/99-sinless-kubernetes.cfg
    permissions: '0644'
    owner: root:root
    content: |
      preserve_hostname: true
      manage_etc_hosts: false

  - path: /etc/systemd/resolved.conf.d/99-sinless-kubernetes.conf
    permissions: '0644'
    owner: root:root
    content: |
      [Resolve]
      DNS={% for ns in (kubernetes_deploy_network_nameservers | default('1.1.1.1 1.0.0.1')).split() %}{{ ns }}{% if not loop.last %} {% endif %}{% endfor %}
      Domains={{ kubernetes_deploy_search_domain | default(kubernetes_deploy_environment ~ '.sinlessgames.local') }}

runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl restart qemu-guest-agent
  - hostnamectl set-hostname k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }} --static
  - mkdir -p /etc/resolv.conf.d
  - |
    cat >/etc/resolv.conf.d/99-custom-dns <<'EOF'
{% for ns in (kubernetes_deploy_network_nameservers | default('1.1.1.1 1.0.0.1')).split() %}
    nameserver {{ ns }}
{% endfor %}
    search {{ kubernetes_deploy_search_domain | default(kubernetes_deploy_environment ~ '.sinlessgames.local') }}
    EOF
  - systemctl restart systemd-resolved || true
  - echo "Cloud-init completed at $(date -Is)" > /var/log/cloud-init-complete.log

final_message: "Cloud-init has completed for k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' % ((node_index | int) + 1) }} at $TIMESTAMP"