module "kubernetes_prod_control_plane" {
  source = "./modules/proxmox-vm-cluster"

  cluster_name = "{{ kubernetes_cluster_name }}"
  environment  = "{{ kubernetes_environment }}"
  service_name = "kubernetes"
  node_role    = "control-plane"

  nodes = [
{% for node in kubernetes_nodes.control_plane %}
    {
      name        = "{{ node.name }}"
      vmid        = {{ node.vmid }}
      target_node = "{{ node.target_node }}"
      storage     = "{{ node.storage | default(kubernetes_proxmox.storage_by_node[node.target_node] | default(kubernetes_proxmox.storage)) }}"
{% if node.clone_template is defined %}
      clone_template = "{{ node.clone_template }}"
{% endif %}
{% if node.gpu_passthrough_devices is defined and (node.gpu_passthrough_devices | length) > 0 %}
  gpu_passthrough_devices = [{% for gpu in node.gpu_passthrough_devices %}"{{ gpu }}"{{ ", " if not loop.last else "" }}{% endfor %}]
{% endif %}
      ip_address  = "{{ node.ip }}"
      hostname    = "{{ node.hostname }}"
      fqdn        = "{{ node.fqdn }}"
    }{{ "," if not loop.last else "" }}
{% endfor %}
  ]

  clone_template                = "{{ kubernetes_control_plane.clone_template }}"
  storage                       = "{{ kubernetes_proxmox.storage }}"
  resource_pool                 = "{{ kubernetes_resource_pool }}"
  cpu_cores                     = {{ kubernetes_control_plane.cpu_cores }}
  cpu_sockets                   = {{ kubernetes_control_plane.cpu_sockets }}
  memory_mb                     = {{ kubernetes_control_plane.memory_mb }}
  memory_balloon_mb             = {{ kubernetes_control_plane.memory_balloon_mb | default('null') }}
  disk_size                     = "{{ kubernetes_control_plane.disk_size }}"
  network_bridge                = "{{ kubernetes_network.bridge }}"
  vlan_id                       = {{ kubernetes_network.vlan_id }}
  gateway                       = "{{ kubernetes_network.gateway }}"
  cidr_subnet                   = "{{ kubernetes_network.cidr_suffix }}"
  nameservers                   = "{{ kubernetes_network.nameservers }}"
  search_domain                 = "{{ kubernetes_search_domain }}"
  ssh_keys                      = var.kubernetes_ssh_keys
  default_user                  = "{{ kubernetes_ansible.default_user }}"
  cicustom_user_snippet_enabled = false
  tags                          = ["kubernetes", "rke2", "prod", "control-plane"]
  startup_order                 = {{ kubernetes_control_plane.startup_order }}
  force_create                  = {{ kubernetes_force_create | bool | lower }}
}

