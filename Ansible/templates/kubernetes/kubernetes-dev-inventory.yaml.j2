kubernetes_dev:
  vars:
    ansible_user: "{{ kubernetes_ansible_user }}"
    ansible_ssh_private_key_file: "{{ kubernetes_ssh_private_key_file }}"
    ansible_python_interpreter: "{{ kubernetes_python_interpreter }}"
    ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
    kubernetes_environment: "{{ kubernetes_environment }}"
  children:
    kubernetes_dev_control_plane:
      hosts:
{% for node in kubernetes_nodes.control_plane %}
        {{ node.name }}:
          ansible_host: {{ node.ip }}
          node_role: control-plane
          node_fqdn: {{ node.fqdn }}
{% endfor %}
    kubernetes_dev_workers:
      hosts:
{% for node in kubernetes_nodes.workers %}
        {{ node.name }}:
          ansible_host: {{ node.ip }}
          node_role: worker
          node_fqdn: {{ node.fqdn }}
{% endfor %}
