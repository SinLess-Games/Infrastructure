{% set tf_env_name = (kubernetes_deploy_environment | replace('-', '_')) %}
{% set master_module_name = 'kubernetes_' ~ tf_env_name ~ '_master' %}
{% set worker_module_name = 'kubernetes_' ~ tf_env_name ~ '_worker' %}
{% set cluster_status_output_name = 'cluster_status_' ~ tf_env_name %}

// ============================================================================
// Kubernetes Cluster Terraform Configuration - Generated by Ansible
// ============================================================================
// Source: Ansible/roles/kubernetes-deploy/tasks/main.yaml
// Template: Ansible/roles/kubernetes-deploy/templates/k8s-dev-cluster.tf.j2
// DO NOT EDIT MANUALLY - this file is overwritten during deployment
// ============================================================================

module "{{ master_module_name }}" {
  source = "./modules/proxmox-vm-cluster"

  # --------------------------------------------------------------------------
  # Cluster identity
  # --------------------------------------------------------------------------
  cluster_name = "{{ kubernetes_deploy_cluster_name }}"
  environment  = "{{ kubernetes_deploy_environment }}"
  service_name = "kubernetes"
  node_role    = "master"

  # --------------------------------------------------------------------------
  # Node definitions
  # --------------------------------------------------------------------------
  nodes = [
{%- for i in range(kubernetes_deploy_master_count | int) %}
{%- set target_node = kubernetes_deploy_master_target_nodes[i % (kubernetes_deploy_master_target_nodes | length)] %}
    {
      name        = "k8s-{{ kubernetes_deploy_environment }}-master-{{ '%02d' | format(i + 1) }}"
      vmid        = {{ kubernetes_deploy_master_vm_id_start | int + i }}
      target_node = "{{ target_node }}"
      ip_address  = "{{ kubernetes_deploy_master_ip_addresses[i] }}"
      hostname    = "k8s-{{ kubernetes_deploy_environment }}-master-{{ '%02d' | format(i + 1) }}"
      fqdn        = "k8s-{{ kubernetes_deploy_environment }}-master-{{ '%02d' | format(i + 1) }}.{{ kubernetes_deploy_search_domain }}"
      storage     = "{{ kubernetes_proxmox.storage_by_node[target_node] | default(kubernetes_proxmox.storage) }}"
    }{{ "," if not loop.last else "" }}
{%- endfor %}
  ]

  # --------------------------------------------------------------------------
  # Proxmox configuration
  # --------------------------------------------------------------------------
  clone_template = "{{ kubernetes_deploy_master_clone_template }}"
  storage        = "{{ kubernetes_proxmox.storage }}"

  # --------------------------------------------------------------------------
  # Resource allocation
  # --------------------------------------------------------------------------
  cpu_cores   = {{ kubernetes_deploy_master_cpu_cores }}
  cpu_sockets = {{ kubernetes_deploy_master_cpu_sockets | default(1) }}
  memory_mb   = {{ kubernetes_deploy_master_memory_mb }}
  disk_size   = "{{ kubernetes_deploy_master_disk_size }}"

  # --------------------------------------------------------------------------
  # Network configuration
  # --------------------------------------------------------------------------
  network_bridge = "{{ kubernetes_deploy_network_bridge }}"
  vlan_id        = {{ kubernetes_deploy_network_vlan_id }}
  gateway        = "{{ kubernetes_deploy_master_gateway }}"
  cidr_subnet    = "{{ kubernetes_deploy_network_cidr_suffix }}"
  nameservers    = "{{ kubernetes_deploy_network_nameservers }}"
  search_domain  = "{{ kubernetes_deploy_search_domain }}"

  # --------------------------------------------------------------------------
  # Metadata / access
  # --------------------------------------------------------------------------
  tags = [
    "kubernetes",
    "rke2",
    "master"
  ]

  ssh_keys     = var.kubernetes_ssh_keys
  default_user = "{{ kubernetes_default_user | default('sinless777') }}"
  cicustom_user_snippet_enabled = false

  # --------------------------------------------------------------------------
  # Lifecycle
  # --------------------------------------------------------------------------
  start_at_node_boot = true
  force_create       = {{ kubernetes_force_create | default(true) | lower }}
  startup_order      = {{ kubernetes_deploy_master_startup_order }}
}

module "{{ worker_module_name }}" {
  source = "./modules/proxmox-vm-cluster"

  # --------------------------------------------------------------------------
  # Cluster identity
  # --------------------------------------------------------------------------
  cluster_name = "{{ kubernetes_deploy_cluster_name }}"
  environment  = "{{ kubernetes_deploy_environment }}"
  service_name = "kubernetes"
  node_role    = "worker"

  # --------------------------------------------------------------------------
  # Node definitions
  # --------------------------------------------------------------------------
  nodes = [
{%- for i in range(kubernetes_deploy_worker_count | int) %}
{%- set target_node = kubernetes_deploy_worker_target_nodes[i % (kubernetes_deploy_worker_target_nodes | length)] %}
    {
      name        = "k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' | format(i + 1) }}"
      vmid        = {{ kubernetes_deploy_worker_vm_id_start | int + i }}
      target_node = "{{ target_node }}"
      ip_address  = "{{ kubernetes_deploy_worker_ip_addresses[i] }}"
      hostname    = "k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' | format(i + 1) }}"
      fqdn        = "k8s-{{ kubernetes_deploy_environment }}-worker-{{ '%02d' | format(i + 1) }}.{{ kubernetes_deploy_search_domain }}"
      storage     = "{{ kubernetes_proxmox.storage_by_node[target_node] | default(kubernetes_proxmox.storage) }}"
    }{{ "," if not loop.last else "" }}
{%- endfor %}
  ]

  # --------------------------------------------------------------------------
  # Proxmox configuration
  # --------------------------------------------------------------------------
  clone_template = "{{ kubernetes_deploy_worker_clone_template }}"
  storage        = "{{ kubernetes_proxmox.storage }}"

  # --------------------------------------------------------------------------
  # Resource allocation
  # --------------------------------------------------------------------------
  cpu_cores   = {{ kubernetes_deploy_worker_cpu_cores }}
  cpu_sockets = {{ kubernetes_deploy_worker_cpu_sockets | default(1) }}
  memory_mb   = {{ kubernetes_deploy_worker_memory_mb }}
  disk_size   = "{{ kubernetes_deploy_worker_disk_size }}"

  # --------------------------------------------------------------------------
  # Network configuration
  # --------------------------------------------------------------------------
  network_bridge = "{{ kubernetes_deploy_network_bridge }}"
  vlan_id        = {{ kubernetes_deploy_network_vlan_id }}
  gateway        = "{{ kubernetes_deploy_worker_gateway }}"
  cidr_subnet    = "{{ kubernetes_deploy_network_cidr_suffix }}"
  nameservers    = "{{ kubernetes_deploy_network_nameservers }}"
  search_domain  = "{{ kubernetes_deploy_search_domain }}"

  # --------------------------------------------------------------------------
  # Metadata / access
  # --------------------------------------------------------------------------
  tags = [
    "kubernetes",
    "rke2",
    "worker"
  ]

  ssh_keys     = var.kubernetes_ssh_keys
  default_user = "{{ kubernetes_default_user | default('sinless777') }}"
  cicustom_user_snippet_enabled = false

  # --------------------------------------------------------------------------
  # Lifecycle
  # --------------------------------------------------------------------------
  start_at_node_boot = true
  force_create       = {{ kubernetes_force_create | default(true) | lower }}
  startup_order      = {{ kubernetes_deploy_worker_startup_order }}

  depends_on = [module.{{ master_module_name }}]
}

// ============================================================================
// Outputs
// ============================================================================

output "{{ cluster_status_output_name }}" {
  description = "Kubernetes cluster VM deployment status for {{ kubernetes_deploy_environment }}"
  value = {
    cluster_name  = "{{ kubernetes_deploy_cluster_name }}"
    environment   = "{{ kubernetes_deploy_environment }}"
    master_count  = {{ kubernetes_deploy_master_count }}
    worker_count  = {{ kubernetes_deploy_worker_count }}
    vlan_id       = {{ kubernetes_deploy_network_vlan_id }}
    pod_cidr      = "{{ kubernetes_deploy_cluster_cidr }}"
    service_cidr  = "{{ kubernetes_deploy_service_cidr }}"
    cluster_dns   = "{{ kubernetes_deploy_cluster_dns }}"
    search_domain = "{{ kubernetes_deploy_search_domain }}"
    master_ips    = {{ kubernetes_deploy_master_ip_addresses | to_json }}
    worker_ips    = {{ kubernetes_deploy_worker_ip_addresses | to_json }}
  }
}
