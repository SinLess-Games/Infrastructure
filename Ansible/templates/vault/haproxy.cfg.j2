# HAProxy configuration for Vault load balancing
global
  log /dev/log local0
  log /dev/log local1 notice
  chroot /var/lib/haproxy
  stats socket /run/haproxy/admin.sock mode 660 level admin
  stats timeout 30s
  user haproxy
  group haproxy
  lua-load /etc/haproxy/terraform-vault-auth.lua

defaults
  log     global
  mode    tcp
  option  tcplog
  timeout connect 5000ms
  timeout client  50000ms
  timeout server  50000ms

# HTTP defaults for Terraform backend
defaults http-defaults
  mode    http
  option  httplog
  timeout connect 5000ms
  timeout client  50000ms
  timeout server  50000ms
  timeout http-request 10s
  timeout http-keep-alive 10s

# Stats page (optional)
listen stats
  bind 0.0.0.0:8404
  stats enable
  stats uri /stats
  stats refresh 30s
  stats show-legends

# Vault API load balancer on standard HTTPS port (TLS passthrough)
listen vault-api-443
  bind {{ vault_haproxy_bind_address }}:443
  mode tcp
  balance roundrobin
  default-server inter 10s fall 3 rise 2
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_api_addr_port }}
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_api_addr_port }}
{% endfor %}
{% endif %}

# Vault API load balancer on legacy port (TLS passthrough)
listen vault-api-8200
  bind {{ vault_haproxy_bind_address }}:{{ vault_api_addr_port }}
  mode tcp
  balance roundrobin
  default-server inter 10s fall 3 rise 2
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_api_addr_port }}
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_api_addr_port }}
{% endfor %}
{% endif %}

# Vault cluster communication (internal only - TLS passthrough)
listen vault-cluster
  bind {{ vault_haproxy_bind_address }}:{{ vault_cluster_addr_port }}
  mode tcp
  balance roundrobin
  default-server inter 10s fall 3 rise 2
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_cluster_addr_port }}
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_cluster_addr_port }}
{% endfor %}
{% endif %}

# =============================================================================
# Terraform HTTP State Backend Integration
# =============================================================================
# This frontend/backend translates Terraform HTTP backend requests to Vault KV API  
# Port 8180 for HTTP state operations (separate from main Vault API)

frontend terraform-state-http
  bind {{ vault_haproxy_bind_address }}:8180 ssl crt /etc/haproxy/vault-combined.pem
  mode http
  option httplog
  option forwardfor
  
  # Extract basic auth password (Vault token) and convert to X-Vault-Token header
  http-request lua.terraform_vault_auth
  
  # Use the terraform-state-backend
  default_backend vault-kv-api

backend vault-kv-api
  mode http
  balance roundrobin
  option httpchk GET /v1/sys/health
  http-check expect status 200
  
  # Unwrap Vault KV v1 response to extract Terraform state
  http-response lua.unwrap_vault_response
  
  # SSL/TLS settings for backend connection to Vault
{% if vault_cluster_nodes is defined and vault_cluster_nodes | length > 0 %}
{% for node in vault_cluster_nodes %}
  server {{ node.name }} {{ node.ip_address }}:{{ vault_api_addr_port }} check ssl verify none
{% endfor %}
{% else %}
{% for host in groups['vault'] %}
  server {{ host }} {{ hostvars[host].ansible_host | default(hostvars[host].inventory_hostname) }}:{{ vault_api_addr_port }} check ssl verify none
{% endfor %}
{% endif %}
