// =====================================================================
// Vault Cluster Terraform Configuration (Managed by Ansible)
// =====================================================================
// Source: Ansible/roles/vault-deploy/templates/vault-cluster.tf.j2
// DO NOT EDIT MANUALLY
// =====================================================================

module "vault_cluster" {
  source = "{{ vault_module_source }}"

  # Cluster configuration
  cluster_name     = "{{ vault_cluster_name }}"
  environment      = "{{ vault_environment }}"
  service_name     = "vault"
  node_role        = "vault"

  # Proxmox placement (HA distribution)
  nodes = [
  {%- for i in range(vault_node_count | int) %}
    {
      name        = "{{ vault_node_name_prefix }}-{{ '%02d' | format(i + 1) }}"
      vmid        = {{ vault_vm_id_start | int + i }}
      target_node = "{{ vault_target_nodes[i % (vault_target_nodes | length)] }}"
      ip_address  = "{{ vault_ip_addresses[i] }}"
      hostname    = "{{ vault_node_name_prefix }}-{{ '%02d' | format(i + 1) }}"
      fqdn        = "{{ vault_node_name_prefix }}-{{ '%02d' | format(i + 1) }}.{{ local_domain | default('local') }}"
    }{{ "," if not loop.last else "" }}
  {%- endfor %}
  ]
  clone_template = "{{ vault_clone_template }}"

  # Network configuration
  gateway        = "{{ vault_gateway }}"
  cidr_subnet    = "{{ vault_cidr_subnet }}"
  vlan_id        = {{ vault_vlan_id }}
  network_bridge = "{{ vault_network_bridge }}"
  nameservers    = "{{ vault_nameservers }}"

  # Resource allocation
  cpu_cores   = {{ vault_cpu_cores }}
  cpu_sockets = {{ vault_cpu_sockets }}
  memory_mb   = {{ vault_memory_mb }}
  disk_size   = "{{ vault_disk_size }}"
  storage     = "{{ vault_storage }}"

  # Access configuration
  default_user     = "{{ vault_default_user }}"
  default_password = "{{ vault_default_password }}"
  ssh_keys         = {{ vault_ssh_keys | to_json }}
  backup_enabled   = {{ vault_backup_enabled | ternary('true', 'false') }}

  # VM options
  start_at_node_boot = {{ vault_start_at_node_boot | ternary('true', 'false') }}
  agent_enabled      = {{ vault_agent_enabled | ternary('true', 'false') }}
  protection    = {{ vault_protection | ternary('true', 'false') }}
  startup_order = {{ vault_startup_order }}

  # Tags and metadata
  tags        = {{ vault_tags | to_json }}
  description = "{{ vault_description }}"
}

resource "null_resource" "generate_inventory" {
  triggers = {
    cluster_nodes = join(",", module.vault_cluster.vm_names)
  }

  provisioner "local-exec" {
    command = <<-EOT
      mkdir -p "$(dirname "$INVENTORY_PATH")"
      {
        cat <<EOF
---
vault_{{ vault_environment }}:
  hosts:
EOF
        echo "$NODES_JSON" | jq -r \
          --arg ansible_user "$ANSIBLE_USER" \
          --arg cluster_name "$CLUSTER_NAME" \
          --arg vault_port "$VAULT_PORT" \
          --arg vault_cluster_port "$VAULT_CLUSTER_PORT" \
          '.[] | "    \(.name):\n      ansible_host: \(.ip_address)\n      ansible_user: \($ansible_user)\n      vault_node_id: \(.name)\n      vault_node_index: \(.node_index)\n      vault_cluster_name: \($cluster_name)\n      vault_api_addr: \"https://\(.ip_address):\($vault_port)\"\n      vault_cluster_addr: \"https://\(.ip_address):\($vault_cluster_port)\"\n      vault_raft_leader: \(if .node_index == 1 then \"true\" else \"false\" end)"'
        cat <<EOF
  vars:
    vault_version: "{{ vault_version }}"
    vault_port: {{ vault_port }}
    vault_cluster_port: {{ vault_cluster_port }}
    vault_storage_path: "{{ vault_storage_path }}"
    vault_log_path: "{{ vault_log_path }}"
    vault_tls_enabled: {{ vault_tls_enabled | ternary('true', 'false') }}
    vault_environment: "{{ vault_environment }}"
EOF
      } > "$INVENTORY_PATH"
    EOT

    environment = {
      INVENTORY_PATH      = "${path.root}/inventory/vault-{{ vault_environment }}.yaml"
      ANSIBLE_USER        = "{{ vault_ansible_user }}"
      CLUSTER_NAME        = "{{ vault_cluster_name }}"
      VAULT_PORT          = "{{ vault_port }}"
      VAULT_CLUSTER_PORT  = "{{ vault_cluster_port }}"
      NODES_JSON          = jsonencode(module.vault_cluster.nodes)
    }
  }
}
