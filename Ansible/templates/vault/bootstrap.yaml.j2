---
cluster:
  name: "{{ vault_cluster_name }}"
  nodes:
{% for node in vault_cluster_nodes %}
    - name: "{{ node.name }}"
      ip_address: "{{ node.ip_address }}"
{% endfor %}
  vip: "{{ vault_keepalived_virtual_ip }}"
  public_addr: "{{ vault_bootstrap_addr }}"

auth_methods:
{% for auth_method in vault_auth_methods %}
  - type: "{{ auth_method.type }}"
    path: "{{ auth_method.path }}"
{% endfor %}

kv_mounts:
{% for mount_name, mount_config in (vault_kv_mounts | default({})).items() %}
  - path: "{{ mount_name }}"
    description: "{{ mount_config.description | default('KV v2 secrets engine') }}"
{% endfor %}

engine_mounts:
{% for mount_name, mount_config in (vault_engine_mounts | default({})).items() %}
  - path: "{{ mount_name }}"
    type: "{{ mount_config.type }}"
    description: "{{ mount_config.description | default('Vault secrets engine') }}"
{% endfor %}

policies:
{% for policy_name in (vault_user_policies | default({})).keys() | list | sort %}
  - "{{ policy_name }}"
{% endfor %}

users:
{% for user in vault_users | default([]) %}
  - username: "{{ user.name }}"
    description: "{{ user.description | default('') }}"
    policies: {{ user.policies | default([]) | to_json }}
{% endfor %}
