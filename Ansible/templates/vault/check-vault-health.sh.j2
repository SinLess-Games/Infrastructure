#!/bin/bash
# Health check script for Vault - used by Keepalived

VAULT_ADDR="{{ vault_api_addr_protocol }}://{{ ansible_host | default(inventory_hostname) }}:{{ vault_api_addr_port }}"
VAULT_SKIP_VERIFY="true"  # In production, use proper certificates

# Check if Vault is healthy (initialized and unsealed)
# We don't check standby status because HAProxy will route to the active node
HEALTH_JSON=$(curl -sk --connect-timeout 2 "${VAULT_ADDR}/v1/sys/health" 2>/dev/null)
INITIALIZED=$(echo "${HEALTH_JSON}" | jq -r '.initialized' 2>/dev/null)
SEALED=$(echo "${HEALTH_JSON}" | jq -r '.sealed' 2>/dev/null)

if [ "${INITIALIZED}" = "true" ] && [ "${SEALED}" = "false" ]; then
  exit 0  # Vault is healthy and can participate in VIP
else
  exit 1  # Vault is not healthy
fi
