#!/usr/bin/env bash
set -euo pipefail

: "${VAULT_ADDR:?VAULT_ADDR is required}"
: "${VAULT_TOKEN:?VAULT_TOKEN is required}"

USERNAME="${1:?username required}"
PASSWORD="${2:?password required}"
POLICIES="${3:-default}"

export VAULT_CACERT="${VAULT_CACERT:-{{ vault_tls_ca_cert_file }}}"

vault write "auth/userpass/users/${USERNAME}" \
  password="${PASSWORD}" \
  token_policies="${POLICIES}" >/dev/null

printf 'configured user %s\n' "${USERNAME}"
