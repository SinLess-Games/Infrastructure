#!/usr/bin/env bash
set -euo pipefail

: "${VAULT_ADDR:?VAULT_ADDR is required}"
: "${VAULT_TOKEN:?VAULT_TOKEN is required}"

USERNAME="${1:?username required}"
POLICIES="${2:-default}"
TTL="${3:-{{ vault_user_token_ttl }}}"

export VAULT_CACERT="${VAULT_CACERT:-{{ vault_tls_ca_cert_file }}}"

IFS=',' read -r -a policy_args <<< "${POLICIES}"
ARGS=()
for policy in "${policy_args[@]}"; do
  ARGS+=("-policy=${policy}")
done

vault token create \
  -display-name="{{ vault_user_token_display_name_prefix }}-${USERNAME}" \
  -ttl="${TTL}" \
  -renewable=true \
  -format=json \
  "${ARGS[@]}"
