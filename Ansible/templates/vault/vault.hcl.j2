ui = {{ vault_ui_enabled | bool | lower }}
disable_mlock = {{ vault_disable_mlock | bool | lower }}
cluster_name = "{{ vault_cluster_name }}"

storage "raft" {
  path    = "{{ vault_data_dir }}"
  node_id = "{{ inventory_hostname }}"
{% if vault_raft_retry_join_enabled | bool and inventory_hostname != vault_primary_host %}
{% for peer in vault_peer_nodes %}
  retry_join {
    leader_api_addr = "{{ vault_api_addr_protocol }}://{{ hostvars[peer].ansible_host | default(peer) }}:{{ vault_service_api_port }}"
    leader_ca_cert_file = "{{ vault_tls_ca_cert_file }}"
  }
{% endfor %}
{% endif %}
}

listener "tcp" {
  address         = "{{ vault_listener_address_effective }}"
  cluster_address = "{{ ansible_host | default(inventory_hostname) }}:{{ vault_service_cluster_port }}"
  tls_disable     = {{ vault_tls_disable | bool | lower }}
{% if not (vault_tls_disable | bool) %}
  tls_cert_file   = "{{ vault_tls_cert_file }}"
  tls_key_file    = "{{ vault_tls_key_file }}"
  tls_client_ca_file = "{{ vault_tls_ca_cert_file }}"
{% endif %}
}

api_addr = "{{ vault_api_addr_effective }}"
cluster_addr = "{{ vault_cluster_addr_effective }}"
plugin_directory = "{{ vault_plugin_directory }}"
log_level = "{{ vault_log_level }}"

default_lease_ttl = "{{ vault_default_lease_duration }}"
max_lease_ttl = "{{ vault_max_lease_duration }}"

telemetry {
  prometheus_retention_time = "24h"
  disable_hostname = true
}

{% if vault_seal_type == 'transit' %}
seal "transit" {
  address            = "{{ vault_transit_address }}"
  token              = "{{ vault_transit_token }}"
  disable_renewal    = {{ vault_transit_disable_renewal | default(false) | bool | lower }}
  key_name           = "{{ vault_transit_key_name }}"
  mount_path         = "{{ vault_transit_mount_path | default('transit') }}"
  tls_skip_verify    = {{ vault_transit_skip_verify | default(false) | bool | lower }}
}
{% endif %}
