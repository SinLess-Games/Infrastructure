# =====================================================================
# aliases.zsh — common CLI aliases
# This file is sourced by .zshrc. Keep logic minimal and side-effect free.
# =====================================================================

# -------------------------- Basic Aliases -----------------------------
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'
alias c='clear'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias mkdirp='mkdir -p'
alias path='echo -e ${PATH//:/\\n}'

# -------------------------- File & Editing ----------------------------
alias e='nvim'
alias v='nvim'
alias cat='bat --style=plain --paging=never 2>/dev/null || command cat'
alias grep='grep --color=auto'

# -------------------------- System Info -------------------------------
alias cpu='lscpu'
alias mem='free -h'
alias ds='du -sh *'
alias ports='ss -tulpn'
alias ipinfo='ip -c a'
alias myip='curl -s https://ipinfo.io/ip'
alias sctl='sudo systemctl'
alias j='journalctl -xe'

# -------------------------- Git Aliases -------------------------------
alias gs='git status'
alias gl='git log --oneline --graph --decorate'
alias gll='git log --stat'
alias gd='git diff'
alias gds='git diff --staged'
alias gc='git commit -m'
alias gca='git commit -am'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gpull='git pull --rebase'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias ga='git add .'
alias gr='git restore'
alias grs='git restore --staged .'
alias gclean='git clean -xdf'
alias gundo='git reset HEAD~1'

# -------------------------- Kubernetes -------------------------------
alias k='kubectl'
alias ka='kubectl apply -f'
alias kd='kubectl delete -f'
alias kga='kubectl get all'
alias kgp='kubectl get pods -o wide'
alias kgn='kubectl get nodes -o wide'
alias kgc='kubectl config get-contexts'
alias kuc='kubectl config use-context'
alias kdn='kubectl describe node'
alias kdp='kubectl describe pod'
alias kl='kubectl logs'
alias klf='kubectl logs -f'
alias kexec='kubectl exec -it'
alias ktop='kubectl top pod'
alias kns='kubectl config set-context --current --namespace'
alias kctx='kubectx'
alias kn='kubens'

# -------------------------- Helm -------------------------------------
alias h='helm'
alias hi='helm install'
alias hu='helm upgrade'
alias hd='helm delete'
alias hrs='helm repo update'

# -------------------------- Terraform -------------------------------
alias tf='terraform'
alias tfi='terraform init'
alias tfp='terraform plan'
alias tfa='terraform apply'
alias tfd='terraform destroy'
alias tff='terraform fmt'
alias tfv='terraform validate'
alias tfs='terraform state list'

# -------------------------- Ansible ----------------------------------
alias a='ansible'
alias ap='ansible-playbook'
alias av='ansible-vault'
alias ainv='ansible-inventory --graph'
alias pingall='ansible all -m ping'

# -------------------------- Docker / Compose --------------------------
alias dps='docker ps'
alias dpa='docker ps -a'
alias dimg='docker images'
alias dstats='docker stats'
alias dstop='docker stop $(docker ps -aq)'
alias drm='docker rm $(docker ps -aq)'
alias drmi='docker rmi $(docker images -q)'
alias dlogin='docker exec -it'
alias dc='docker compose'

if command -v docker-compose >/dev/null 2>&1; then
  alias dco='docker-compose'
fi

alias dcb='docker compose build'
alias dcu='docker compose up'
alias dcud='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs'
alias dclf='docker compose logs -f'

# -------------------------- Networking & Debug ------------------------
alias pingg='ping google.com'
alias trace='traceroute'
alias ns='netstat -tulpn 2>/dev/null || ss -tulpn'
alias digg='dig +short'
alias flushdns='sudo systemd-resolve --flush-caches'

# -------------------------- Processes --------------------------------
alias psg='ps aux | grep -i'
alias topu='top -u $USER'
alias kill9='kill -9'

# -------------------------- Python -----------------------------------
alias py='python3'
alias pipu='pip install --user'
alias venv='python3 -m venv .venv'

# -------------------------- Node / NPM --------------------------------
alias ni='npm install'
alias nr='npm run'
alias ns='npm start'
alias nrb='npm run build'
alias yt='yarn test'
alias yb='yarn build'

# -------------------------- Misc DevOps Tools -------------------------
alias k9='kill -9'
alias rmds='find . -name ".DS_Store" -delete'
alias watch='watch -n 1'
alias t='task'
alias mk='make'
alias kc='kubecolor 2>/dev/null || kubectl'

# =====================================================================
# End of aliases.zsh
# =====================================================================