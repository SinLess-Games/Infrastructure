# =====================================================================
# prompt.zsh — native Zsh prompt inspired by the previous Starship layout
# =====================================================================

autoload -Uz add-zsh-hook vcs_info colors
colors

zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' formats '%F{green}🌿 %b%f'
zstyle ':vcs_info:git:*' actionformats '%F{yellow}🌿 %b|%a%f'

typeset -g _prompt_cmd_start=0
typeset -g _prompt_cmd_duration=""

_prompt_repo_root() {
  command git rev-parse --show-toplevel 2>/dev/null
}

_prompt_local_ip() {
  local ip_addr=""

  if command -v hostname >/dev/null 2>&1; then
    ip_addr="$(hostname -I 2>/dev/null | awk '{print $1}')"
  fi

  if [[ -z "$ip_addr" ]] && command -v ip >/dev/null 2>&1; then
    ip_addr="$(ip route get 1.1.1.1 2>/dev/null | awk '/src/ {for (i = 1; i <= NF; i++) if ($i == "src") {print $(i+1); exit}}')"
  fi

  [[ -n "$ip_addr" ]] && printf '%s' "$ip_addr"
}

_prompt_repo_has_any() {
  local repo_root="$1"
  shift

  if command -v rg >/dev/null 2>&1; then
    rg --files "$repo_root" 2>/dev/null | rg -q "$1"
  else
    find "$repo_root" -type f 2>/dev/null | grep -Eq "$1"
  fi
}

_prompt_preexec() {
  _prompt_cmd_start=$EPOCHSECONDS
}

_prompt_precmd() {
  local last_status=$?
  local now=$EPOCHSECONDS
  local clock=""
  local local_ip=""
  local repo_root=""
  local git_line=""
  local conditionals_line=""
  local languages_line=""
  local duration_segment=""
  local status_segment=""
  local character_segment=""
  local kube_context=""

  vcs_info
  repo_root="$(_prompt_repo_root)"
  local_ip="$(_prompt_local_ip)"

  if [[ -n "${vcs_info_msg_0_}" ]]; then
    local git_dirty=""
    local modified_count=0
    local deleted_count=0
    local added_count=0
    local ahead_count=0
    local line_stats=""
    local staged_shortstat=""
    local unstaged_shortstat=""
    local total_added=0
    local total_deleted=0

    if command git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      modified_count=$(
        {
          command git diff --name-status 2>/dev/null
          command git diff --cached --name-status 2>/dev/null
          command git ls-files --others --exclude-standard 2>/dev/null | sed 's/^/A\t/'
        } | awk '$1 == "M" || $1 == "R" {count++} END {print count + 0}'
      )
      deleted_count=$(
        {
          command git diff --name-status 2>/dev/null
          command git diff --cached --name-status 2>/dev/null
        } | awk '$1 == "D" {count++} END {print count + 0}'
      )
      added_count=$(
        {
          command git diff --name-status 2>/dev/null
          command git diff --cached --name-status 2>/dev/null
          command git ls-files --others --exclude-standard 2>/dev/null | sed 's/^/A\t/'
        } | awk '$1 == "A" {count++} END {print count + 0}'
      )
      ahead_count="$(command git rev-list --count @{upstream}..HEAD 2>/dev/null || printf '0')"

      staged_shortstat="$(command git diff --cached --shortstat 2>/dev/null)"
      unstaged_shortstat="$(command git diff --shortstat 2>/dev/null)"
      total_added=$(
        printf '%s\n%s\n' "$staged_shortstat" "$unstaged_shortstat" \
          | awk -F',' '
              {
                for (i = 1; i <= NF; i++) {
                  if ($i ~ /insertion/) {
                    gsub(/[^0-9]/, "", $i)
                    add += $i
                  }
                  if ($i ~ /deletion/) {
                    gsub(/[^0-9]/, "", $i)
                    del += $i
                  }
                }
              }
              END { print add + 0 }
            '
      )
      total_deleted=$(
        printf '%s\n%s\n' "$staged_shortstat" "$unstaged_shortstat" \
          | awk -F',' '
              {
                for (i = 1; i <= NF; i++) {
                  if ($i ~ /deletion/) {
                    gsub(/[^0-9]/, "", $i)
                    del += $i
                  }
                }
              }
              END { print del + 0 }
            '
      )

      [[ -n "$(command git status --porcelain 2>/dev/null)" ]] && git_dirty=" %F{yellow}• dirty%f"
      line_stats=" %F{red}🗑 ${deleted_count}%f %F{yellow}📝 ${modified_count}%f %F{green}✨ ${added_count}%f"
      (( ahead_count > 0 )) && line_stats+=" %F{blue}⬆ ${ahead_count}%f"
      (( total_added > 0 || total_deleted > 0 )) && line_stats+=" %F{green}+${total_added}%f %F{red}-${total_deleted}%f"
    fi

    git_line="${vcs_info_msg_0_}${git_dirty}${line_stats}"
  else
    git_line="%F{8}clean%f"
  fi

  if (( _prompt_cmd_start > 0 )); then
    local elapsed=$(( now - _prompt_cmd_start ))
    if (( elapsed >= 2 )); then
      duration_segment="%F{8}${elapsed}s%f "
    fi
  fi

  if (( last_status == 0 )); then
    status_segment="%F{green}ok%f "
    character_segment="%F{green}➜%f"
  else
    status_segment="%F{red}exit:${last_status}%f "
    character_segment="%F{red}✗%f"
  fi

  if zmodload zsh/datetime 2>/dev/null; then
    clock="$(strftime '%I:%M:%S %p' "$now")"
  else
    clock="$(date '+%I:%M:%S %p' 2>/dev/null)"
  fi

  if command -v kubectl >/dev/null 2>&1 && [[ -d "$HOME/.kube" || -n "${KUBECONFIG:-}" ]]; then
    kube_context="$(kubectl config current-context 2>/dev/null)"
    [[ -n "$kube_context" ]] && conditionals_line+=" %F{cyan}☸ ${kube_context}%f"
  fi
  [[ -f "Chart.yaml" || -f "helmfile.yaml" ]] && conditionals_line+=" %F{cyan}⎈ helm%f"
  ([[ -d ".terraform" ]] || compgen -G "*.tf" >/dev/null) && conditionals_line+=" %F{magenta}🧱 terraform%f"
  ([[ -f "Dockerfile" || -f "compose.yaml" || -f "compose.yml" || -f "docker-compose.yaml" || -f "docker-compose.yml" ]]) && conditionals_line+=" %F{cyan}🐳 docker%f"
  [[ -f "package.json" ]] && conditionals_line+=" %F{8}📦 package%f"
  [[ -z "$conditionals_line" ]] && conditionals_line=" %F{8}none%f"

  if [[ -n "$repo_root" ]] && command -v node >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/)(package\.json|\.nvmrc)$'; then
    languages_line+=" %F{green}⬢ $(node --version 2>/dev/null)%f"
  fi
  if [[ -n "$repo_root" ]] && command -v python3 >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/)(pyproject\.toml|requirements(\.[^/]*)?\.txt|requirements\.txt|\.python-version|.*\.py)$'; then
    local python_path=""
    local python_version=""
    local venv_name=""

    python_path="$(command -v python3 2>/dev/null)"
    python_version="$(python3 --version 2>/dev/null | awk '{print $2}')"
    if [[ -n "${VIRTUAL_ENV:-}" ]]; then
      venv_name="${VIRTUAL_ENV:t}"
    elif [[ -n "$python_path" && "$python_path" == */bin/python(|[0-9.]#) ]]; then
      venv_name="${${python_path:h}:h:t}"
      [[ "$venv_name" == "usr" || "$venv_name" == "opt" || "$venv_name" == "bin" ]] && venv_name=""
    fi

    if [[ -n "$venv_name" ]]; then
      languages_line+=" %F{yellow}🐍 ${venv_name}:${python_version}%f"
    else
      languages_line+=" %F{yellow}🐍 ${python_version}%f"
    fi
  fi
  if [[ -n "$repo_root" ]] && command -v bash >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/).*\.(sh|bash)$'; then
    languages_line+=" %F{cyan}⌘ $(bash --version 2>/dev/null | awk 'NR==1 {print $4}')%f"
  fi
  if [[ -n "$repo_root" ]] && command -v go >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/)(go\.mod|go\.work|.*\.go)$'; then
    languages_line+=" %F{green}◉ $(go version 2>/dev/null | awk '{print $3}' | sed 's/^go//')%f"
  fi
  if [[ -n "$repo_root" ]] && command -v rustc >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/)(Cargo\.toml|.*\.rs)$'; then
    languages_line+=" %F{red}🦀 $(rustc --version 2>/dev/null | awk '{print $2}')%f"
  fi
  if [[ -n "$repo_root" ]] && command -v terraform >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/).*\.tf(vars)?$'; then
    languages_line+=" %F{magenta}⬡ $(terraform version 2>/dev/null | sed -n '1s/^Terraform v//p')%f"
  fi
  if [[ -n "$repo_root" ]] && command -v ansible >/dev/null 2>&1 && _prompt_repo_has_any "$repo_root" '(^|/)(Ansible/|.*ansible.*\.ya?ml$|requirements\.ya?ml$)'; then
    languages_line+=" %F{blue}⚙ $(ansible --version 2>/dev/null | sed -n '1s/.*core \\([^]]*\\)].*/\\1/p')%f"
  fi
  if _prompt_repo_has_any "${repo_root:-$PWD}" '(^|/).*\.(j2|jinja|jinja2)$'; then
    languages_line+=" %F{cyan}◌%f"
  fi
  [[ -z "$languages_line" ]] && languages_line=" %F{8}none%f"

  PROMPT=$'%F{cyan}╔══════════════════════════%f %F{cyan}%n%f%F{green} | %f%F{blue}%m%f'
  [[ -n "$local_ip" ]] && PROMPT+=$' %F{green}|%f %F{cyan}'"${local_ip}"$'%f'
  PROMPT+=$' %F{8}'"${clock}"$'%f %F{cyan}═════════════════════════════╗%f\n'
  PROMPT+=$'%F{cyan}║%f %F{green} Git%f '"${git_line}"$'\n'
  PROMPT+=$'%F{cyan}║%f %F{green} Conditionals%f'"${conditionals_line}"$'\n'
  PROMPT+=$'%F{cyan}║%f %F{green} Languages%f'"${languages_line}"$'\n'
  PROMPT+=$'%F{cyan}║%f %F{green} Dir%f %B%~%b\n'
  PROMPT+=$'%F{cyan}╚══>%f '"${duration_segment} ${status_segment} ${character_segment} "
}

add-zsh-hook preexec _prompt_preexec
add-zsh-hook precmd _prompt_precmd
