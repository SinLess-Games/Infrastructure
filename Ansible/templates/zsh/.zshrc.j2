{# =====================================================================
   .zshrc.j2 — Jinja-safe Zsh configuration (FIXED)
   ===================================================================== #}

{% set oh_my_zsh_path = user.home_directory ~ "/.oh-my-zsh" %}
{% set omz_builtin_plugins = [
  'aliases', 'ansible', 'aws', 'azure', 'brew', 'docker', 'docker-compose',
  'git', 'gh', 'helm', 'kubectl', 'terraform', 'sudo', 'systemd', 'vscode',
  'ssh', 'ssh-agent', 'zoxide'
] %}
{% set custom_plugin_names = plugins | default([]) | map(attribute='name') | list %}
{% set rendered_plugins = (omz_builtin_plugins + custom_plugin_names) | unique | list %}

# =====================================================================
# Zsh Shell Configuration
# =====================================================================

unset -f source 2>/dev/null || true
unalias source 2>/dev/null || true

setopt nullglob

# -------------------------- General Zsh Options --------------------------
setopt autocd interactivecomments magicequalsubst nonomatch notify numericglobsort promptsubst
setopt transient_rprompt
WORDCHARS=${WORDCHARS//\\//}
PROMPT_EOL_MARK=""

# -------------------------- Keybindings --------------------------
bindkey -e
bindkey ' '        magic-space
bindkey '^U'       backward-kill-line
bindkey '^[[3;5~'  kill-word
bindkey '^[[3~'    delete-char
bindkey '^[[1;5C'  forward-word
bindkey '^[[1;5D'  backward-word
bindkey '^[[5~'    beginning-of-buffer-or-history
bindkey '^[[6~'    end-of-buffer-or-history
bindkey '^[[H'     beginning-of-line
bindkey '^[[F'     end-of-line
bindkey '^[[Z'     undo

# -----------------------------------------------------------------------------
# Base PATH setup
# -----------------------------------------------------------------------------

# User binaries first
export PATH="$HOME/bin:$HOME/.local/bin:$HOME/.npm-global/bin:$PATH"

# Python (pip user installs)
export PATH="$HOME/.local/bin:$PATH"

# Homebrew (Linuxbrew)
if [ -d "/home/linuxbrew/.linuxbrew/bin" ]; then
  export PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:$PATH"
fi

# Snap
if [ -d "/snap/bin" ]; then
  export PATH="/snap/bin:$PATH"
fi

# Node / npm global configuration
export NPM_CONFIG_PREFIX="$HOME/.npm-global"
export PATH="$NPM_CONFIG_PREFIX/bin:$PATH"

# Allow Python virtualenvs to override system python
export PATH="$HOME/.venv/bin:$PATH"

# Deduplicate PATH entries while preserving order
typeset -U path PATH
# -------------------------- Environment --------------------------
export ZSH="{{ oh_my_zsh_path }}"
export HOMEBREW_NO_ENV_HINTS=1
export DIRENV_LOG_FORMAT=

# -------------------------- Oh My Zsh --------------------------
ZSH_THEME=""

plugins=(
{% for plugin_name in rendered_plugins %}
  {{ plugin_name }}
{% endfor %}
)

if [[ -s "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# -------------------------- Completion --------------------------
autoload -Uz compinit
mkdir -p ~/.cache
compinit -d ~/.cache/zcompdump

# -------------------------- History --------------------------
HISTFILE=~/.zsh_history
HISTSIZE=5000
SAVEHIST=10000
setopt hist_ignore_dups hist_ignore_space hist_verify share_history

# -------------------------- Aliases --------------------------
source ~/.zsh_aliases 2>/dev/null || true

# -------------------------- Prompt --------------------------
source ~/.zsh_prompt 2>/dev/null || true

# -------------------------- direnv --------------------------
if command -v direnv >/dev/null 2>&1; then
  eval "$(command direnv hook zsh)"
fi

# -------------------------- Virtualenv Sync --------------------------
typeset -g _ZSH_MANAGED_VENV=""

_sync_direnv_virtualenv() {
  local desired_venv="${VIRTUAL_ENV:-}"
  local desired_bin=""

  if [[ -n "$_ZSH_MANAGED_VENV" ]]; then
    path=(${path:#"${_ZSH_MANAGED_VENV}/bin"})
  fi

  if [[ -n "$desired_venv" && -d "$desired_venv/bin" ]]; then
    desired_bin="${desired_venv}/bin"
    path=("$desired_bin" ${path:#"$desired_bin"})
    export VIRTUAL_ENV="$desired_venv"
    _ZSH_MANAGED_VENV="$desired_venv"
  else
    unset VIRTUAL_ENV
    _ZSH_MANAGED_VENV=""
  fi

  export PATH="${(j.:.)path}"
}

autoload -Uz add-zsh-hook
add-zsh-hook precmd _sync_direnv_virtualenv
add-zsh-hook chpwd _sync_direnv_virtualenv
_sync_direnv_virtualenv

# -------------------------- zoxide --------------------------
if command -v zoxide >/dev/null 2>&1; then
  eval "$(command zoxide init zsh)"
fi

# --------------------------- SSH Agent ---------------------------------------
# Universal, cert-safe, idempotent SSH agent bootstrap
# -----------------------------------------------------------------------------

SSH_ENV="$HOME/.ssh/agent.env"

_ssh_agent_load() {
  [[ -f "$SSH_ENV" ]] || return 1
  source "$SSH_ENV" >/dev/null 2>&1
  [[ -n "$SSH_AGENT_PID" ]] && kill -0 "$SSH_AGENT_PID" 2>/dev/null
}

_ssh_agent_start() {
  umask 077
  ssh-agent -s | sed 's/^echo/#echo/' >| "$SSH_ENV"
  source "$SSH_ENV" >/dev/null 2>&1
}

if ! _ssh_agent_load; then
  _ssh_agent_start
fi

# Load keys only if agent is empty
if ! ssh-add -l >/dev/null 2>&1; then
  for key in "$HOME/.ssh"/id_* "$HOME/.ssh"/*_id_*; do
    [[ -f "$key" ]] || continue
    [[ "$key" == *.pub ]] && continue
    [[ "$key" == *-cert.pub ]] && continue

    if ssh-keygen -yf "$key" >/dev/null 2>&1; then
      ssh-add "$key" >/dev/null 2>&1
    fi
  done
fi

unset SSH_ENV
