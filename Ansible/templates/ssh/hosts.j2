# -------------------------------------------------------------------
# /etc/hosts managed by Ansible
# -------------------------------------------------------------------
127.0.0.1 localhost.localdomain localhost

# The following lines are desirable for IPv6 capable hosts
::1     ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
ff02::3 ip6-allhosts

# -------------------------------------------------------------------
# Managed Host Entries
# -------------------------------------------------------------------
# Entries generated by Ansible. Do not edit manually.
# -------------------------------------------------------------------
{% for host in groups['all'] %}
{% set ipv4 = hostvars[host]['ansible_default_ipv4']['address'] if hostvars[host]['ansible_default_ipv4'] is defined else '' %}
{% set fqdn = hostvars[host]['ansible_fqdn'] if hostvars[host]['ansible_fqdn'] is defined else host %}
{% set short = hostvars[host]['ansible_hostname'] if hostvars[host]['ansible_hostname'] is defined else host %}
{% if ipv4 %}
{{ ipv4 }} {{ fqdn }} {{ short }} \
{{ short }}.local.sinlessgames.com {{ fqdn }}.local.sinlessgames.com \
{{ short }}.local.sinlessgamesllc.com {{ fqdn }}.local.sinlessgamesllc.com
{% endif %}
{% endfor %}

# -------------------------------------------------------------------
# End of managed entries
# -------------------------------------------------------------------