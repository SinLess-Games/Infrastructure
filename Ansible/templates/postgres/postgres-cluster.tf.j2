// =====================================================================
// Postgres Cluster Terraform Configuration (Managed by Ansible)
// =====================================================================
// Source: Ansible/templates/postgres/postgres-cluster.tf.j2
// DO NOT EDIT MANUALLY
// =====================================================================

module "postgres_cluster" {
  source = "{{ postgres_module_source }}"

  # Cluster configuration
  cluster_name     = "{{ postgres_cluster_name }}"
  environment      = "{{ postgres_environment }}"
  service_name     = "postgres"
  node_role        = "database"

  # Proxmox placement (HA distribution)
  nodes = [
  {%- for node in postgres_nodes %}
    {
      name        = "{{ node.name }}"
      vmid        = {{ node.vmid }}
      target_node = "{{ node.target_node }}"
      ip_address  = "{{ node.ip }}"
      hostname    = "{{ node.name }}"
      fqdn        = "{{ node.name }}.{{ local_domain | default('local') }}"
    }{{ "," if not loop.last else "" }}
  {%- endfor %}
  ]
  clone_template = "{{ postgres_clone_template }}"

  # Network configuration
  gateway        = "{{ postgres_gateway }}"
  cidr_subnet    = "{{ postgres_cidr_subnet }}"
  vlan_id        = {{ postgres_vlan_id }}
  network_bridge = "{{ postgres_network_bridge }}"
  nameservers    = "{{ postgres_nameservers }}"

  # Resource allocation
  cpu_cores   = {{ postgres_cpu_cores }}
  cpu_sockets = {{ postgres_cpu_sockets }}
  memory_mb   = {{ postgres_memory_mb }}
  disk_size   = "{{ postgres_disk_size }}"
  storage     = "{{ postgres_storage }}"

  # Access configuration
  default_user = "{{ postgres_default_user }}"
  default_password = "{{ postgres_default_password }}"
  ssh_keys     = {{ postgres_ssh_keys | to_json }}
  backup_enabled = {{ postgres_backup_enabled | ternary('true', 'false') }}

  # VM options
  start_at_node_boot = {{ postgres_start_at_node_boot | ternary('true', 'false') }}
  agent_enabled      = {{ postgres_agent_enabled | ternary('true', 'false') }}
  protection    = {{ postgres_protection | ternary('true', 'false') }}
  startup_order = {{ postgres_startup_order }}

  # Tags and metadata
  tags        = {{ postgres_tags | to_json }}
  description = "{{ postgres_description }}"
}
