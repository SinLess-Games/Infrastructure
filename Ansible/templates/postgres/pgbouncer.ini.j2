[databases]
{% for db in postgres_database_names_effective | default(postgres_database_names) %}
{{ db }} = host=127.0.0.1 port={{ postgres_listen_port }} dbname={{ db }}
{% endfor %}

{% set node = postgres_nodes | selectattr('name', 'equalto', inventory_hostname) | first %}
[pgbouncer]
logfile = /var/log/postgresql/pgbouncer.log
pidfile = /var/run/postgresql/pgbouncer.pid
listen_addr = {{ node.ip }}
listen_port = 6432
unix_socket_dir = /var/run/postgresql
auth_type = scram-sha-256
auth_file = /etc/pgbouncer/userlist.txt
admin_users = {{ patroni.superuser.username }}
stats_users = {{ patroni.superuser.username }}

pool_mode = transaction
max_client_conn = 1000
default_pool_size = 25
reserve_pool_size = 5
reserve_pool_timeout = 3
max_db_connections = 100
max_user_connections = 100

server_reset_query = DISCARD ALL
server_check_query = SELECT 1
server_check_delay = 30
server_lifetime = 3600
server_idle_timeout = 600

log_connections = 1
log_disconnections = 1
log_pooler_errors = 1
