# =============================================================================
# Proxmox VE Network Interfaces Configuration
# =============================================================================
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Node: {{ inventory_hostname }}
# 
# Configuration template: roles/proxmox-networking/templates/interfaces.j2
# Configuration variables: group_vars/proxmox/networking.yaml
#
# Network parameters:
#   Management Network: {{ proxmox_management_network }}
#   Cluster Network: {{ proxmox_cluster_network }}
#
# To apply changes after review:
#   1. sudo cp /etc/network/interfaces.new /etc/network/interfaces
#   2. sudo ifreload -a
#   3. Monitor: watch -n 1 ip link show
# =============================================================================

# ==============================================================================
# LOOPBACK INTERFACE (Required)
# ==============================================================================
auto lo
iface lo inet loopback

{% set mgmt_iface_items = node_interfaces | dict2items %}
{% set primary_mgmt_iface = (mgmt_iface_items | map(attribute='key') | list | first | default('')) %}
{% set primary_mgmt_cfg = (mgmt_iface_items | map(attribute='value') | list | first | default({})) %}
{% set vmbr0_cfg = (merged_bridges.get('vmbr0', {}) if (merged_bridges is mapping) else {}) %}
{% set vmbr0_has_address = (vmbr0_cfg.get('address') | default('') | string | length) > 0 %}
{% set vmbr0_gateway = vmbr0_cfg.get('gateway', primary_mgmt_cfg.get('gateway', '')) %}
{% set ns = namespace(bridge_ports=[], declared_ifaces=[], vlan_ifaces=[]) %}
{% for _iface_name, _iface_cfg in node_interfaces.items() %}
{% if _iface_name not in ns.declared_ifaces %}
{% set _ = ns.declared_ifaces.append(_iface_name) %}
{% endif %}
{% endfor %}
{% for _bridge_name, _bridge_cfg in merged_bridges.items() %}
{% for _port in _bridge_cfg.get('ports', []) %}
{% if _port not in ns.bridge_ports %}
{% set _ = ns.bridge_ports.append(_port) %}
{% endif %}
{% if _port not in ns.declared_ifaces %}
{% set _ = ns.declared_ifaces.append(_port) %}
{% endif %}
{% if (_bridge_cfg.get('vlan_id', 1) | int) > 1 and (_bridge_cfg.get('vlan_tagged', true) | bool) %}
{% set _vlan_port = _port ~ '.' ~ (_bridge_cfg.get('vlan_id') | string) %}
{% if _vlan_port not in ns.vlan_ifaces %}
{% set _ = ns.vlan_ifaces.append(_vlan_port) %}
{% endif %}
{% if _vlan_port not in ns.declared_ifaces %}
{% set _ = ns.declared_ifaces.append(_vlan_port) %}
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}
{% for _bond_name, _bond_cfg in node_bonds.items() %}
{% if _bond_name not in ns.declared_ifaces %}
{% set _ = ns.declared_ifaces.append(_bond_name) %}
{% endif %}
{% for _slave in _bond_cfg.interfaces | default([]) %}
{% if _slave not in ns.declared_ifaces %}
{% set _ = ns.declared_ifaces.append(_slave) %}
{% endif %}
{% endfor %}
{% endfor %}

# ==============================================================================
# MANAGEMENT INTERFACE(S)
# ==============================================================================
# Primary management IP for cluster communication
{% for iface_name, iface_config in node_interfaces.items() %}

auto {{ iface_name }}
{% if vmbr0_has_address or iface_name in ns.bridge_ports %}
iface {{ iface_name }} inet manual
{% else %}
iface {{ iface_name }} inet static
{% if iface_config.get('inet') %}
	address {{ iface_config.inet }}
{% endif %}
{% if iface_config.get('netmask') %}
	netmask {{ iface_config.netmask }}
{% endif %}
{% if iface_config.get('gateway') %}
	gateway {{ iface_config.gateway }}
{% endif %}
{% endif %}
{% endfor %}

# ==============================================================================
# BOND CONFIGURATION (if any)
# ==============================================================================
{% if node_bonds | length > 0 %}
{% for bond_name, bond_config in node_bonds.items() %}

# Bond: {{ bond_name }}
# Mode: {{ bond_config.mode }}
# Slave interfaces: {{ bond_config.interfaces | join(', ') }}
{% for slave_iface in bond_config.interfaces %}
auto {{ slave_iface }}
iface {{ slave_iface }} inet manual
	bond-master {{ bond_name }}
	bond-slave yes
{% endfor %}

auto {{ bond_name }}
iface {{ bond_name }} inet manual
	bond-mode {{ bond_config.mode }}
	bond-miimon {{ bond_config.miimon }}
{% if bond_config.get('lacp_rate') %}
	bond-lacp-rate {{ bond_config.lacp_rate }}
{% endif %}
{% if bond_config.get('xmit_hash_policy') %}
	bond-xmit-hash-policy {{ bond_config.xmit_hash_policy }}
{% endif %}
	mtu 1500
{% endfor %}
{% endif %}

# ==============================================================================
# VLAN SUBINTERFACES
# ==============================================================================
# Access VLAN bridges use per-VLAN subinterfaces instead of bridge VLAN filtering.
{% for bridge_name, bridge_config in merged_bridges.items() | sort %}
{% if (bridge_config.get('vlan_id', 1) | int) > 1 and (bridge_config.get('vlan_tagged', true) | bool) %}
{% for bridge_port in bridge_config.get('ports', []) %}

auto {{ bridge_port }}.{{ bridge_config.vlan_id }}
iface {{ bridge_port }}.{{ bridge_config.vlan_id }} inet manual
	vlan-raw-device {{ bridge_port }}
{% endfor %}
{% endif %}
{% endfor %}

# ==============================================================================
# OTHER PHYSICAL INTERFACES (Manual)
# ==============================================================================
# Keep additional NICs explicitly defined to avoid implicit behavior changes.
{% for iface_name in (ansible_facts.interfaces | default([]) | sort) %}
{% if iface_name not in ns.declared_ifaces and iface_name is match('^(en|eth|eno|ens|enp|ib|wl|ww)') %}

auto {{ iface_name }}
iface {{ iface_name }} inet manual
{% endif %}
{% endfor %}

# ==============================================================================
# VLAN BRIDGES
# ==============================================================================
# These bridges provide network segmentation using VLANs.
# Each bridge below represents a separate network segment.
#
# VM Configuration:
#   - Attach VM NIC to desired bridge (e.g., vmbr40)
#   - For untagged access, set VLAN tag to 0 in Proxmox GUI
#   - For tagged access, set appropriate VLAN tag in Proxmox GUI
#
# Network breakdown:
{% for name, config in merged_bridges.items() | sort %}
#   {{ name }}: VLAN {{ config.vlan_id }} - {{ config.description }}
{% endfor %}
#
# ==============================================================================
{% for bridge_name, bridge_config in merged_bridges.items() | sort %}

# {{ bridge_config.description }}
# VLAN ID: {{ bridge_config.vlan_id }}
# Network: {{ bridge_config.vlan_id == 1 and proxmox_management_network or 'VLAN ' + (bridge_config.vlan_id | string) }}
{% if bridge_config.get('ports', []) | length > 0 %}
# Physical ports: {{ bridge_config.ports | join(', ') }}
{% endif %}
{% if bridge_config.get('address') %}

auto {{ bridge_name }}
iface {{ bridge_name }} inet static
	address {{ bridge_config.address }}
{% if bridge_name == 'vmbr0' and vmbr0_gateway %}
	gateway {{ vmbr0_gateway }}
{% endif %}
{% else %}

auto {{ bridge_name }}
iface {{ bridge_name }} inet manual
{% endif %}
{% set bridge_ports = [] %}
{% for bridge_port in bridge_config.get('ports', []) %}
{% if (bridge_config.get('vlan_id', 1) | int) > 1 and (bridge_config.get('vlan_tagged', true) | bool) %}
{% set _ = bridge_ports.append(bridge_port ~ '.' ~ (bridge_config.vlan_id | string)) %}
{% else %}
{% set _ = bridge_ports.append(bridge_port) %}
{% endif %}
{% endfor %}
	bridge-ports {{ bridge_ports | join(' ') if bridge_ports | length > 0 else 'none' }}
	bridge-stp {{ 'on' if bridge_config.get('stp', true) else 'off' }}
	bridge-fd {{ bridge_config.get('stp_forward_delay', 0) }}
	mtu 1500
{% endfor %}

# ==============================================================================
# NETWORK NOTES
# ==============================================================================
{% if node_bonds | length > 0 %}
#
# BONDING:
# Bond aggregation is configured for redundancy and load balancing.
# Physical ports are bonded together in {{ node_bonds | dict2items | map(attribute='key') | list | join(', ') }}.
# Ensure your switch uplinks are configured for LACP aggregation.
{% endif %}
