apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: kube-vip
  namespace: kube-system
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: kube-vip
  template:
    metadata:
      labels:
        app.kubernetes.io/name: kube-vip
    spec:
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      enableServiceLinks: false
      automountServiceAccountToken: false
      nodeSelector:
        node-role.kubernetes.io/control-plane: "true"
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          operator: Exists
          effect: NoSchedule
        - key: node-role.kubernetes.io/master
          operator: Exists
          effect: NoSchedule
      hostAliases:
        - ip: "127.0.0.1"
          hostnames:
            - kubernetes
      containers:
        - name: kube-vip
          image: "{{ kubernetes_kube_vip.image }}"
          imagePullPolicy: IfNotPresent
          args:
            - manager
          env:
            - name: vip_arp
              value: "{{ kubernetes_kube_vip.arp | ternary('true', 'false') }}"
            - name: vip_nodename
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
            - name: port
              value: "6443"
            - name: vip_interface
              value: "{{ kubernetes_kube_vip.interface }}"
            - name: vip_cidr
              value: "{{ kubernetes_kube_vip.cidr }}"
            - name: vip_address
              value: "{{ kubernetes_kube_vip.vip }}"
            - name: address
              value: "{{ kubernetes_kube_vip.vip }}"
            - name: cp_enable
              value: "{{ kubernetes_kube_vip.controlplane | ternary('true', 'false') }}"
            - name: cp_namespace
              value: kube-system
            - name: svc_enable
              value: "{{ kubernetes_kube_vip.services | ternary('true', 'false') }}"
            - name: vip_leaderelection
              value: "{{ kubernetes_kube_vip.leader_election | ternary('true', 'false') }}"
            - name: vip_leaseduration
              value: "{{ kubernetes_kube_vip.lease_duration | default(15) }}"
            - name: vip_renewdeadline
              value: "{{ kubernetes_kube_vip.renew_deadline | default(10) }}"
            - name: vip_retryperiod
              value: "{{ kubernetes_kube_vip.retry_period | default(2) }}"
            - name: KUBECONFIG
              value: /etc/kubernetes/admin.conf
            # Static control-plane pods may not resolve the in-cluster `kubernetes` DNS name.
            # Pin API discovery to the local RKE2 apiserver endpoint used on control-plane hosts.
            - name: KUBERNETES_SERVICE_HOST
              value: "127.0.0.1"
            - name: KUBERNETES_SERVICE_PORT
              value: "6443"
          securityContext:
            capabilities:
              add:
                - NET_ADMIN
                - NET_RAW
                - SYS_TIME
          resources:
            requests:
              cpu: 25m
              memory: 64Mi
            limits:
              cpu: 200m
              memory: 256Mi
          volumeMounts:
            - mountPath: /etc/kubernetes/admin.conf
              name: kubeconfig
      volumes:
        - hostPath:
            path: /etc/rancher/rke2/rke2.yaml
            type: FileOrCreate
          name: kubeconfig
