# =============================================================================
# Proxmox VE Network Interfaces Configuration
# =============================================================================
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Node: {{ inventory_hostname }}
# 
# Original management interface and vmbr0 configuration preserved from existing setup.
# Additional VLAN bridges (vmbr20-60) added by Ansible.
# See: Ansible/group_vars/proxmox/networking.yaml
#
# To apply changes:
#   1. Review this configuration carefully
#   2. Run: ifreload -a (to test)
#   3. Or manually: systemctl restart networking
# =============================================================================

# ==============================================================================
# PRESERVED ORIGINAL CONFIGURATION (Management Interface + vmbr0)
# ==============================================================================
{{ original_config.stdout }}

# ==============================================================================
# ANSIBLE-MANAGED VLAN BRIDGES (Added by proxmox-networking role)
# ==============================================================================
# The following bridges are managed by Ansible for VLAN segmentation.
# To configure VMs to use these VLANs, attach them to the appropriate bridge
# and set the VLAN tag in the Proxmox GUI or via qm set command.
# Example: qm set 100 -net0 virtio,bridge=vmbr20,tag=20
# ==============================================================================


{% set node_overrides = proxmox_node_bridges.get(inventory_hostname, {}) %}
{% set merged_bridges = proxmox_bridges.copy() %}
{% for bridge_name, override_config in node_overrides.items() %}
{%   if override_config is not none %}
{%     set _ = merged_bridges.update({bridge_name: override_config}) %}
{%   elif bridge_name in merged_bridges %}
{%     set _ = merged_bridges.pop(bridge_name) %}
{%   endif %}
{% endfor %}

{% for bridge_name, bridge_config in merged_bridges.items() | sort %}
{% if bridge_name != 'vmbr0' %}
# {{ bridge_config.description }}
# VLAN {{ bridge_config.vlan_id }}
{% if bridge_config.ports %}
# Physical ports: {{ bridge_config.ports | join(', ') }}
{% endif %}
auto {{ bridge_name }}
iface {{ bridge_name }} inet {{ 'static' if bridge_config.get('address') else 'manual' }}
{% if bridge_config.get('address') %}
	address {{ bridge_config.address }}
{% endif %}
	bridge-ports {{ bridge_config.ports | join(' ') if bridge_config.ports else 'none' }}
	bridge-stp {{ 'on' if bridge_config.get('stp', true) else 'off' }}
	bridge-fd {{ bridge_config.get('stp_forward_delay', 0) }}
	bridge-vlan-aware {{ 'yes' if bridge_config.get('vlan_aware', true) else 'no' }}
{% if bridge_config.get('vlan_aware', true) %}	bridge-pvid {{ bridge_config.vlan_id }}
	bridge-vids {{ bridge_config.vlan_id }}
{% else %}	post_up /sbin/ip link set {{ bridge_name }} type bridge vlan_filtering 0
{% endif %}	mtu 1500

{% endif %}
{% endfor %}

# =============================================================================
# VLAN Configuration Notes
# =============================================================================
# These bridges are VLAN-aware and support tagged traffic on all VLANs.
# 
# VM Configuration Example:
# For a VM on VLAN 20 (Development):
#   - Set hardware: Bridge: vmbr0, VLAN tag: 20
# OR
#   - Use vmbr20 directly (implicit VLAN 20)
#
# For a VM on VLAN 1 (Infrastructure, untagged/native):
#   - Set hardware: Bridge: vmbr0, VLAN tag: (leave empty or use 1)
# OR
#   - Use vmbr0 directly
# =============================================================================
