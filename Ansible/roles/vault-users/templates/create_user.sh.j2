#!/bin/bash
set -euo pipefail

# Variables
VAULT_ADDR="{{ vault_addr | default('https://10.10.10.180:8200') }}"
VAULT_SKIP_VERIFY="true"
VAULT_TOKEN="{{ vault_token }}"
VAULT_BIN="{{ vault_vault_bin | default('/usr/local/bin/vault') }}"
USERNAME="{{ user_item.name }}"
POLICIES="{{ user_item.policies | join(',') }}"

# Export for vault CLI
export VAULT_ADDR
export VAULT_SKIP_VERIFY
export VAULT_TOKEN

# Check if user exists
user_exists=$( $VAULT_BIN read -format=json auth/userpass/users/$USERNAME 2>/dev/null | jq -r '.data.username // empty' )

# Create user if doesn't exist
if [ -z "$user_exists" ]; then
  echo "Creating user: $USERNAME"
  $VAULT_BIN write auth/userpass/users/$USERNAME \
    password="temp_pass_${USERNAME}_$(date +%s)" \
    policies="$POLICIES" 2>&1
else
  echo "User $USERNAME already exists, updating policies..."
  $VAULT_BIN write auth/userpass/users/$USERNAME \
    policies="$POLICIES" 2>&1
fi

# Generate token for the user (this creates an orphan token for automation)
token_output=$( $VAULT_BIN token create \
  -format=json \
  -policies="$POLICIES" \
  -display-name="token_${USERNAME}" \
  -ttl=720h 2>&1 )

echo "$token_output"
