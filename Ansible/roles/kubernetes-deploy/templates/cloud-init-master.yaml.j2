#cloud-config
# RKE2 Control Plane Node Cloud-Init Configuration
# Generated by Ansible - kubernetes-deploy role

version: 2

# Hostname configuration
hostname: k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' % ((node_index | int) + 1) }}
fqdn: k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' % ((node_index | int) + 1) }}.{{ kubernetes_deploy_environment }}.sinlessgames.local

# System configuration
locale: en_US.UTF-8
timezone: UTC

# Package management
package_update: true
package_upgrade: false
packages:
  - qemu-guest-agent
  - curl
  - wget
  - net-tools
  - vim
  - htop
  - sudo

# Default user configuration
users:
  - name: sinless777
    gecos: SinLess Administrator
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: [adm, sudo]
    ssh_authorized_keys:
{% for ssh_key in vault_kubernetes_ansible_development_data.kubernetes_ssh_keys %}
      - {{ ssh_key }}
{% endfor %}

# DNS and system configuration
write_files:
  - path: /etc/hostname
    content: |
      k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' % ((node_index | int) + 1) }}
    permissions: '0644'
  - path: /etc/hosts
    content: |
      127.0.0.1 localhost
      127.0.1.1 k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' % ((node_index | int) + 1) }}
      ::1 localhost ip6-localhost ip6-loopback
      ff02::1 ip6-allnodes
      ff02::2 ip6-allrouters
    permissions: '0644'
  - path: /etc/qemu-ga/client.conf
    content: |
      [general]
      logfile = /var/log/qemu-ga/client.log
    permissions: '0644'

# Run commands
runcmd:
  - systemctl enable qemu-guest-agent
  - systemctl start qemu-guest-agent
  - hostnamectl set-hostname k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' % ((node_index | int) + 1) }} --static
  - mkdir -p /etc/resolv.conf.d
  - echo "nameserver 1.1.1.1" > /etc/resolv.conf.d/99-custom-dns
  - echo "nameserver 1.0.0.1" >> /etc/resolv.conf.d/99-custom-dns
  - systemctl restart systemd-networkd || systemctl restart networking
  - echo "Cloud-init completed at $(date)" > /var/log/cloud-init-complete.log

# Final message
final_message: "Cloud-init has completed for k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' % ((node_index | int) + 1) }} at $TIMESTAMP"
