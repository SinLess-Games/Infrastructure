// =====================================================================
// Kubernetes Development Cluster - Generated by Ansible
// =====================================================================
// Source: Ansible/roles/kubernetes-deploy/tasks/main.yaml
// DO NOT EDIT MANUALLY - will be overwritten on deployment
// =====================================================================

module "kubernetes_master" {
  source = "./modules/kubernetes-master"

  # Cluster configuration
  cluster_name = "{{ kubernetes_deploy_cluster_name }}"
  environment  = "{{ kubernetes_deploy_environment }}"
  node_role    = "control-plane"

  # Node definitions
  nodes = [
{%- for i in range(kubernetes_deploy_master_count | int) %}
    {
      name        = "k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' | format(i + 1) }}"
      vmid        = {{ kubernetes_deploy_master_vm_id_start | int + i }}
      target_node = "{{ kubernetes_deploy_master_target_nodes[i % (kubernetes_deploy_master_target_nodes | length)] }}"
      ip_address  = "{{ kubernetes_deploy_master_ip_addresses[i] }}"
      hostname    = "k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' | format(i + 1) }}"
      fqdn        = "k8s-{{ kubernetes_deploy_environment }}-cp-{{ '%02d' | format(i + 1) }}.{{ kubernetes_deploy_environment }}.sinlessgames.local"
    }{{ "," if not loop.last else "" }}
{%- endfor %}
  ]

  # Proxmox configuration
  clone_template = "{{ kubernetes_deploy_master_clone_template }}"
  storage        = "VM_Disks"

  # Resource allocation
  cpu_cores   = {{ kubernetes_deploy_master_cpu_cores }}
  cpu_sockets = 1
  memory_mb   = {{ kubernetes_deploy_master_memory_mb }}
  disk_size   = "{{ kubernetes_deploy_master_disk_size }}"

  # Network configuration
  network_bridge = "{{ kubernetes_deploy_network_bridge }}"
  vlan_id        = {{ kubernetes_deploy_network_vlan_id }}
  gateway        = "{{ kubernetes_deploy_master_gateway }}"
  cidr_subnet    = "{{ kubernetes_deploy_network_cidr_suffix }}"
  nameservers    = "{{ kubernetes_deploy_network_nameservers }}"

  # Tags
  tags = ["kubernetes", "rke2", "{{ kubernetes_deploy_environment }}", "control-plane"]

  # HA and lifecycle management
  start_at_node_boot = true
  force_create       = true
  startup_order      = {{ kubernetes_deploy_master_startup_order }}
}

module "kubernetes_worker" {
  source = "./modules/kubernetes-worker"

  # Cluster configuration
  cluster_name = "{{ kubernetes_deploy_cluster_name }}"
  environment  = "{{ kubernetes_deploy_environment }}"
  node_role    = "worker"

  # Node definitions
  nodes = [
{%- for i in range(kubernetes_deploy_worker_count | int) %}
    {
      name        = "k8s-{{ kubernetes_deploy_environment }}-wk-{{ '%02d' | format(i + 1) }}"
      vmid        = {{ kubernetes_deploy_worker_vm_id_start | int + i }}
      target_node = "{{ kubernetes_deploy_worker_target_nodes[i % (kubernetes_deploy_worker_target_nodes | length)] }}"
      ip_address  = "{{ kubernetes_deploy_worker_ip_addresses[i] }}"
      hostname    = "k8s-{{ kubernetes_deploy_environment }}-wk-{{ '%02d' | format(i + 1) }}"
      fqdn        = "k8s-{{ kubernetes_deploy_environment }}-wk-{{ '%02d' | format(i + 1) }}.{{ kubernetes_deploy_environment }}.sinlessgames.local"
    }{{ "," if not loop.last else "" }}
{%- endfor %}
  ]

  # Proxmox configuration
  clone_template = "{{ kubernetes_deploy_worker_clone_template }}"
  storage        = "VM_Disks"

  # Resource allocation
  cpu_cores   = {{ kubernetes_deploy_worker_cpu_cores }}
  cpu_sockets = 1
  memory_mb   = {{ kubernetes_deploy_worker_memory_mb }}
  disk_size   = "{{ kubernetes_deploy_worker_disk_size }}"

  # Network configuration
  network_bridge = "{{ kubernetes_deploy_network_bridge }}"
  vlan_id        = {{ kubernetes_deploy_network_vlan_id }}
  gateway        = "{{ kubernetes_deploy_worker_gateway }}"
  cidr_subnet    = "{{ kubernetes_deploy_network_cidr_suffix }}"
  nameservers    = "{{ kubernetes_deploy_network_nameservers }}"

  # Tags
  tags = ["kubernetes", "rke2", "{{ kubernetes_deploy_environment }}", "worker"]

  # HA and lifecycle management
  start_at_node_boot = true
  force_create       = true
  startup_order      = {{ kubernetes_deploy_worker_startup_order }}

  # Depends on master nodes being deployed first
  depends_on = [module.kubernetes_master]
}

// =====================================================================
// Outputs
// =====================================================================

output "cluster_status" {
  description = "Kubernetes cluster deployment status"
  value = {
    cluster_name = "{{ kubernetes_deploy_cluster_name }}"
    environment  = "{{ kubernetes_deploy_environment }}"
    master_count = {{ kubernetes_deploy_master_count }}
    worker_count = {{ kubernetes_deploy_worker_count }}
    vlan_id      = {{ kubernetes_deploy_network_vlan_id }}
    pod_cidr     = "{{ kubernetes_deploy_cluster_cidr }}"
    service_cidr = "{{ kubernetes_deploy_service_cidr }}"
    master_ips   = {{ kubernetes_deploy_master_ip_addresses | to_json }}
    worker_ips   = {{ kubernetes_deploy_worker_ip_addresses | to_json }}
  }
}
