# =============================================================================
# /etc/resolv.conf - Generated by Ansible dns-resolver role
# =============================================================================
# Managed by: {{ role_path | basename }}
# Generated: {{ ansible_date_time.iso8601 }}
# Host: {{ ansible_hostname }}
# =============================================================================

{% if dns_search_domains | length > 0 %}
search {{ dns_search_domains | join(' ') }}
{% endif %}

{% for server in dns_servers %}
nameserver {{ server }}
{% endfor %}

# Options
options timeout:{{ dns_test_timeout }}
options attempts:{{ dns_test_retries }}
options rotate
