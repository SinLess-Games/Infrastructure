// =====================================================================
// Vault Cluster Terraform Configuration (Managed by Ansible)
// =====================================================================
// Source: Ansible/roles/vault-deploy/templates/vault-cluster.tf.j2
// DO NOT EDIT MANUALLY
// =====================================================================

module "vault_cluster" {
  source = "{{ vault_module_source }}"

  # Cluster configuration
  cluster_name     = "{{ vault_cluster_name }}"
  environment      = "{{ vault_environment }}"
  node_count       = {{ vault_node_count }}
  node_name_prefix = "{{ vault_node_name_prefix }}"
  vm_id_start      = {{ vault_vm_id_start }}

  # Proxmox placement (HA distribution)
  target_nodes   = {{ vault_target_nodes | to_json }}
  clone_template = "{{ vault_clone_template }}"

  # Network configuration
  ip_addresses   = {{ vault_ip_addresses | to_json }}
  gateway        = "{{ vault_gateway }}"
  cidr_subnet    = "{{ vault_cidr_subnet }}"
  vlan_id        = {{ vault_vlan_id }}
  network_bridge = "{{ vault_network_bridge }}"
  nameservers    = "{{ vault_nameservers }}"

  # Resource allocation
  cpu_cores   = {{ vault_cpu_cores }}
  cpu_sockets = {{ vault_cpu_sockets }}
  memory_mb   = {{ vault_memory_mb }}
  disk_size   = "{{ vault_disk_size }}"
  storage     = "{{ vault_storage }}"

  # Vault configuration
  vault_version      = "{{ vault_version }}"
  vault_port         = {{ vault_port }}
  vault_cluster_port = {{ vault_cluster_port }}
  vault_storage_path = "{{ vault_storage_path }}"
  vault_log_path     = "{{ vault_log_path }}"

  # TLS configuration
  vault_tls_enabled   = {{ vault_tls_enabled | ternary('true', 'false') }}
  vault_tls_cert_path = "{{ vault_tls_cert_path }}"
  vault_tls_key_path  = "{{ vault_tls_key_path }}"
  vault_tls_ca_path   = "{{ vault_tls_ca_path }}"

  # Access configuration
  default_user = "{{ vault_default_user }}"
  ansible_user = "{{ vault_ansible_user }}"
  ssh_keys     = {{ vault_ssh_keys | to_json }}

  # HA and backup
  ha_enabled      = {{ vault_ha_enabled | ternary('true', 'false') }}
  ha_group        = "{{ vault_ha_group }}"
  backup_enabled  = {{ vault_backup_enabled | ternary('true', 'false') }}
  backup_schedule = "{{ vault_backup_schedule }}"

  # VM options
  start_at_node_boot = {{ vault_start_at_node_boot | ternary('true', 'false') }}
  agent_enabled      = {{ vault_agent_enabled | ternary('true', 'false') }}
  protection    = {{ vault_protection | ternary('true', 'false') }}
  startup_order = {{ vault_startup_order }}

  # Tags and metadata
  tags        = {{ vault_tags | to_json }}
  description = "{{ vault_description }}"
}
