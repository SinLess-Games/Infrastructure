# =============================================================================
# Direnv configuration for Infrastructure / Ansible
# -----------------------------------------------------------------------------
# Automatically configures local runtime, Ansible, Vault, Kubernetes, and
# Terraform defaults when entering this repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Local overrides / secrets
# -----------------------------------------------------------------------------
source_env_if_exists .env

# -----------------------------------------------------------------------------
# Python / virtualenv
# -----------------------------------------------------------------------------
export VIRTUAL_ENV="$PWD/Ansible/.venv"

# -----------------------------------------------------------------------------
# PATH
# -----------------------------------------------------------------------------
export PATH="$VIRTUAL_ENV/bin:$HOME/.local/bin:$PATH"

# -----------------------------------------------------------------------------
# Ansible core configuration
# -----------------------------------------------------------------------------
export ANSIBLE_CONFIG="$PWD/Ansible/ansible.cfg"
export ANSIBLE_INVENTORY="$PWD/Ansible/inventory"
export ANSIBLE_ROLES_PATH="$PWD/Ansible/roles:$PWD/Ansible/playbooks/roles"
export ANSIBLE_COLLECTIONS_PATHS="$PWD/Ansible/.collections:$HOME/.ansible/collections"

# -----------------------------------------------------------------------------
# Ansible behavior / output
# -----------------------------------------------------------------------------
export ANSIBLE_HOST_KEY_CHECKING=False
export ANSIBLE_STDOUT_CALLBACK=yaml
export ANSIBLE_FORCE_COLOR=1

# -----------------------------------------------------------------------------
# Debugging
# -----------------------------------------------------------------------------
export DEBUG=1

# -----------------------------------------------------------------------------
# Vault
# -----------------------------------------------------------------------------
export VAULT_ADDR="${VAULT_ADDR:-https://10.10.10.180:443}"
export VAULT_SKIP_VERIFY="${VAULT_SKIP_VERIFY:-true}"

# Load Vault CA certificate if available
if [[ -f "$PWD/.outputs/vault/vault-ca.pem" ]]; then
  export VAULT_CACERT="$PWD/.outputs/vault/vault-ca.pem"
fi

# Load Vault root token if available
# NOTE: Reload .envrc after Vault initialization to pick up new tokens
if [[ -f "$PWD/.outputs/vault/unseal-keys.json" ]]; then
  export VAULT_TOKEN="$(jq -r '.root_token' "$PWD/.outputs/vault/unseal-keys.json" 2>/dev/null || true)"
  export TF_HTTP_PASSWORD="${VAULT_TOKEN}"
fi

# -----------------------------------------------------------------------------
# PXE / environment defaults
# -----------------------------------------------------------------------------
export PXE_HTTP_HOST="pxe.local.sinlessgames.com"
export DOMAIN="sinlessgames.com"
export LOCAL_DOMAIN="pxe.local.sinlessgames.com"
export PXE_SERVER_IP="10.10.10.10"

# -----------------------------------------------------------------------------
# Kubernetes / kubectl
# -----------------------------------------------------------------------------
export KUBECONFIG="$PWD/.outputs/kubernetes/prod/kubeconfig"

# -----------------------------------------------------------------------------
# Terraform / deployment controls
# -----------------------------------------------------------------------------
export TF_PARALLELISM="${TF_PARALLELISM:-3}"
export KUBERNETES_CONFIGURE_SERIAL="${KUBERNETES_CONFIGURE_SERIAL:-3}"
export KUBERNETES_TERRAFORM_LOCK_TIMEOUT="${KUBERNETES_TERRAFORM_LOCK_TIMEOUT:-10m}"