# =============================================================================
# Direnv configuration for Infrastructure / Ansible
# -----------------------------------------------------------------------------
# Automatically configures Ansible paths and defaults when entering the repo.
# =============================================================================

# --- Python / venv -----------------------------------------------------------
export VIRTUAL_ENV="$PWD/Ansible/.venv"
export PATH="$VIRTUAL_ENV/bin:$PATH"

# --- Ansible core paths ------------------------------------------------------
export ANSIBLE_CONFIG="$PWD/Ansible/ansible.cfg"
export ANSIBLE_ROLES_PATH="$PWD/Ansible/roles:$PWD/Ansible/playbooks/roles"
export ANSIBLE_COLLECTIONS_PATHS="$PWD/Ansible/.collections:$HOME/.ansible/collections"

# --- Behavior / safety -------------------------------------------------------
export ANSIBLE_HOST_KEY_CHECKING=False
export ANSIBLE_STDOUT_CALLBACK=yaml
export ANSIBLE_FORCE_COLOR=1

# --- Inventory --------------------------------------------------------------
export ANSIBLE_INVENTORY="$PWD/Ansible/inventory"

